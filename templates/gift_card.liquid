
<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ gift_card.initial_value | money_without_trailing_zeros }} {{ shop.name }} Gift Card</title>
  {{ content_for_header }}
  {{ 'rv-base.css' | asset_url | stylesheet_tag }}
</head>
<body style="background:var(--rv-bone,#F4F1EA);font-family:'Hanken Grotesk',sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:40px 24px;">
  <div style="max-width:480px;width:100%;text-align:center;">
    <div style="font-family:'Cormorant Garamond',serif;font-size:28px;letter-spacing:.14em;text-transform:uppercase;color:#2B2A27;margin-bottom:32px;">Rare Velvet</div>
    <div style="background:#fff;border:1px solid #DAD4CB;border-radius:4px;padding:40px 32px;">
      <div style="font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:#6E6A64;margin-bottom:12px;">Gift Card</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:52px;color:#2B2A27;font-weight:500;margin-bottom:8px;">{{ gift_card.initial_value | money_without_trailing_zeros }}</div>
      {%- if gift_card.enabled -%}
        <div style="font-size:13px;color:#6E6A64;margin-bottom:24px;">Balance: {{ gift_card.balance | money }}</div>
        <div id="rv-qr-code" data-identifier="{{ gift_card.qr_identifier }}" style="width:160px;height:160px;margin:0 auto 24px;"></div>
        <div style="font-family:monospace;font-size:16px;letter-spacing:.14em;color:#2B2A27;background:#F4F1EA;padding:12px;border-radius:2px;margin-bottom:20px;">{{ gift_card.code | format_code }}</div>
        <p style="font-size:13px;line-height:1.6;color:#56524C;">Use this code at checkout. Never expires.</p>
      {%- else -%}
        <p style="font-size:15px;color:#B0795C;">This gift card has been disabled.</p>
      {%- endif -%}
    </div>
    <div style="margin-top:24px;"><a href="{{ shop.url }}" style="font:600 12px/1 'Hanken Grotesk',sans-serif;letter-spacing:.14em;text-transform:uppercase;color:#2B2A27;border-bottom:1px solid #DAD4CB;">Shop Rare Velvet →</a></div>
  </div>
</body>
</html>
