
{%- comment -%} Slide-out cart drawer — opens on add-to-cart & cart icon {%- endcomment -%}
{%- comment -%} Falls back to the global Theme settings → Cart & shipping threshold so the drawer, cart page and progress bar stay in sync {%- endcomment -%}
{%- assign threshold = section.settings.free_ship_threshold | default: settings.free_ship_threshold | default: 50 -%}
<div class="rv-cd" data-rv-cd aria-hidden="true">
  <div class="rv-cd__scrim" data-rv-cd-close></div>
  <aside class="rv-cd__panel" role="dialog" aria-modal="true" aria-label="Cart">
    <div class="rv-cd__head">
      <span class="rv-cd__title">Your bag (<span data-rv-cd-count>0</span>)</span>
      <button class="rv-cd__close" data-rv-cd-close aria-label="Close cart">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="rv-cd__ship" data-rv-cd-ship></div>
    <div class="rv-cd__items" data-rv-cd-items></div>
    <div class="rv-cd__empty" data-rv-cd-empty style="display:none;">
      <p>Your bag is empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="rv-cd__shop" data-rv-cd-close>Start shopping →</a>
    </div>
    <div class="rv-cd__foot" data-rv-cd-foot style="display:none;">
      <div class="rv-cd__subtotal"><span>Subtotal</span><span data-rv-cd-subtotal></span></div>
      <p class="rv-cd__note">Shipping &amp; taxes calculated at checkout.</p>
      <a href="/checkout" class="rv-cd__checkout">Checkout</a>
      <a href="{{ routes.cart_url }}" class="rv-cd__viewcart" data-rv-cd-close>View bag</a>
    </div>
  </aside>
</div>

<style>
.rv-cd{position:fixed;inset:0;z-index:320;visibility:hidden;}
.rv-cd.is-open{visibility:visible;}
.rv-cd__scrim{position:absolute;inset:0;background:rgba(43,42,39,.34);opacity:0;transition:opacity .3s ease;}
.rv-cd.is-open .rv-cd__scrim{opacity:1;}
.rv-cd__panel{position:absolute;top:0;right:0;height:100%;width:420px;max-width:92vw;background:var(--rv-bone);display:flex;flex-direction:column;transform:translateX(100%);transition:transform .36s cubic-bezier(.2,.7,.2,1);box-shadow:-20px 0 60px -24px rgba(43,42,39,.4);}
.rv-cd.is-open .rv-cd__panel{transform:translateX(0);}
.rv-cd__head{display:flex;align-items:center;justify-content:space-between;padding:22px 24px;border-bottom:1px solid var(--rv-line);}
.rv-cd__title{font-family:var(--rv-serif);font-weight:500;font-size:22px;color:var(--rv-char);}
.rv-cd__close{background:none;border:none;cursor:pointer;color:var(--rv-char);display:flex;}
.rv-cd__ship{padding:16px 24px;border-bottom:1px solid var(--rv-line);font:400 12px/1.4 var(--rv-sans);color:var(--rv-soft);}
.rv-cd__ship-bar{height:5px;background:var(--rv-bone-2);border-radius:999px;overflow:hidden;margin-top:9px;}
.rv-cd__ship-fill{height:100%;background:var(--rv-butter);transition:width .4s ease;}
.rv-cd__items{flex:1;overflow-y:auto;padding:8px 24px;}
.rv-cd__item{display:flex;gap:14px;padding:18px 0;border-bottom:1px solid var(--rv-line);}
.rv-cd__item-img{width:74px;height:92px;flex:none;border-radius:3px;overflow:hidden;background:var(--rv-bone-2);}
.rv-cd__item-img img{width:100%;height:100%;object-fit:cover;display:block;}
.rv-cd__item-main{flex:1;display:flex;flex-direction:column;}
.rv-cd__item-title{font:500 14px/1.3 var(--rv-sans);color:var(--rv-char);text-decoration:none;}
.rv-cd__item-variant{font-family:var(--rv-serif);font-style:italic;font-size:13px;color:var(--rv-grey);margin-top:2px;}
.rv-cd__item-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:auto;}
.rv-cd__qty{display:flex;align-items:center;border:1px solid var(--rv-line);border-radius:2px;}
.rv-cd__qty button{width:28px;height:28px;background:none;border:none;cursor:pointer;color:var(--rv-char);font-size:15px;line-height:1;}
.rv-cd__qty span{min-width:26px;text-align:center;font:500 13px/1 var(--rv-sans);color:var(--rv-char);}
.rv-cd__item-price{font:600 13px/1 var(--rv-sans);color:var(--rv-char);}
.rv-cd__remove{background:none;border:none;cursor:pointer;font:400 11px/1 var(--rv-sans);color:var(--rv-grey-2);text-decoration:underline;padding:0;margin-top:6px;align-self:flex-start;}
.rv-cd__empty{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;color:var(--rv-soft);font:400 15px/1.5 var(--rv-sans);}
.rv-cd__shop{font:600 12px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;color:var(--rv-char);border-bottom:1px solid var(--rv-char);padding-bottom:3px;text-decoration:none;}
.rv-cd__foot{padding:20px 24px;border-top:1px solid var(--rv-line);}
.rv-cd__subtotal{display:flex;align-items:center;justify-content:space-between;font:600 15px/1 var(--rv-sans);color:var(--rv-char);margin-bottom:6px;}
.rv-cd__note{font:400 11px/1.4 var(--rv-sans);color:var(--rv-grey-2);margin:0 0 14px;}
.rv-cd__checkout{display:block;text-align:center;background:var(--rv-clay);color:#FBF9F4;font:600 13px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;padding:16px;border-radius:2px;text-decoration:none;transition:opacity .2s;}
.rv-cd__checkout:hover{opacity:.9;}
.rv-cd__viewcart{display:block;text-align:center;font:500 12px/1 var(--rv-sans);letter-spacing:.08em;color:var(--rv-soft);text-decoration:underline;margin-top:12px;}
</style>

<script>
(function(){
  var root=document.querySelector('[data-rv-cd]');
  if(!root)return;
  var THRESH={{ threshold }}*100;
  var itemsEl=root.querySelector('[data-rv-cd-items]');
  var countEl=root.querySelector('[data-rv-cd-count]');
  var subEl=root.querySelector('[data-rv-cd-subtotal]');
  var shipEl=root.querySelector('[data-rv-cd-ship]');
  var footEl=root.querySelector('[data-rv-cd-foot]');
  var emptyEl=root.querySelector('[data-rv-cd-empty]');

  function money(c){return '$'+(c/100).toFixed(2).replace(/\.00$/,'');}
  function open(){root.classList.add('is-open');root.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';}
  function close(){root.classList.remove('is-open');root.setAttribute('aria-hidden','true');document.body.style.overflow='';}

  function renderShip(total){
    if(total>=THRESH){shipEl.innerHTML='✓ You’ve unlocked <strong>free shipping</strong>.';}
    else{var rem=THRESH-total;var pct=Math.min(100,Math.round(total/THRESH*100));shipEl.innerHTML='You’re '+money(rem)+' away from <strong>free shipping</strong>.<div class="rv-cd__ship-bar"><div class="rv-cd__ship-fill" style="width:'+pct+'%"></div></div>';}
  }

  function render(cart){
    countEl.textContent=cart.item_count;
    document.querySelectorAll('[data-cart-count]').forEach(function(b){b.textContent=cart.item_count;});
    if(!cart.items.length){itemsEl.style.display='none';footEl.style.display='none';shipEl.style.display='none';emptyEl.style.display='flex';return;}
    itemsEl.style.display='';footEl.style.display='';shipEl.style.display='';emptyEl.style.display='none';
    renderShip(cart.total_price);
    itemsEl.innerHTML=cart.items.map(function(it){
      var img=it.image?it.image.replace(/(\.[a-z]+)(\?|$)/i,'_160x$1$2'):'';
      var variant=(it.variant_title&&it.variant_title!=='Default Title')?'<div class="rv-cd__item-variant">'+it.variant_title+'</div>':'';
      return '<div class="rv-cd__item" data-key="'+it.key+'">'
        +'<a class="rv-cd__item-img" href="'+it.url+'">'+(img?'<img src="'+img+'" alt="">':'')+'</a>'
        +'<div class="rv-cd__item-main"><a class="rv-cd__item-title" href="'+it.url+'">'+it.product_title+'</a>'+variant
        +'<div class="rv-cd__item-bottom"><div class="rv-cd__qty"><button data-rv-cd-dec aria-label="Decrease">−</button><span>'+it.quantity+'</span><button data-rv-cd-inc aria-label="Increase">+</button></div>'
        +'<span class="rv-cd__item-price">'+money(it.final_line_price)+'</span></div>'
        +'<button class="rv-cd__remove" data-rv-cd-remove>Remove</button></div></div>';
    }).join('');
    subEl.textContent=money(cart.total_price);
  }

  function refresh(o){fetch('/cart.js').then(function(r){return r.json();}).then(function(c){render(c);if(o)open();});}
  function change(key,qty){
    fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:key,quantity:qty})})
      .then(function(r){return r.json();}).then(function(c){render(c);});
  }

  itemsEl.addEventListener('click',function(e){
    var row=e.target.closest('[data-key]');if(!row)return;var key=row.getAttribute('data-key');
    var qtyEl=row.querySelector('.rv-cd__qty span');var q=parseInt(qtyEl.textContent,10)||1;
    if(e.target.closest('[data-rv-cd-inc]'))change(key,q+1);
    else if(e.target.closest('[data-rv-cd-dec]'))change(key,Math.max(0,q-1));
    else if(e.target.closest('[data-rv-cd-remove]'))change(key,0);
  });

  // open on cart icon click (intercept link to /cart)
  document.querySelectorAll('a[href$="/cart"], a[href*="/cart?"], [data-rv-cart-open]').forEach(function(el){
    if(el.closest('[data-rv-cd]'))return;
    el.addEventListener('click',function(e){e.preventDefault();refresh(true);});
  });
  root.querySelectorAll('[data-rv-cd-close]').forEach(function(el){el.addEventListener('click',close);});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&root.classList.contains('is-open'))close();});

  // open when any add-to-cart fires the shared event
  document.addEventListener('rv:cart:updated',function(e){ if(e.detail) render(e.detail); refresh(true); });

  // initial silent load for the count
  refresh(false);
})();
</script>
{% schema %}{"name":"Cart Drawer","tag":"div","settings":[
{"type":"number","id":"free_ship_threshold","label":"Free shipping threshold ($)","default":50}
]}{% endschema %}
