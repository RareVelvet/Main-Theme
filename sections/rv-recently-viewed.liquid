
<section class="rv-pdp-section" data-rv-recent style="display:none;">
  <div class="rv-container">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:24px;">
      <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(24px,2.6vw,32px);color:var(--rv-char);margin:0;">{{ section.settings.heading }}</h2>
    </div>
    <div data-rv-recent-grid style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;"></div>
  </div>
</section>
<script>
(function(){
  var KEY='rv_recently_viewed';
  var handle={{ product.handle | json }};
  var current={
    handle:handle,
    title:{{ product.title | json }},
    url:{{ product.url | json }},
    price:{{ product.price | money | json }},
    image:{{ product.featured_image | image_url: width: 400 | json }},
    material:{{ product.metafields.custom.material_name | default: '' | json }}
  };
  var list=[];
  try{list=JSON.parse(localStorage.getItem(KEY))||[];}catch(e){list=[];}
  list=list.filter(function(p){return p&&p.handle!==handle;});
  var render=list.slice(0,4);
  var sec=document.querySelector('[data-rv-recent]');
  var grid=document.querySelector('[data-rv-recent-grid]');
  if(grid&&render.length>=2){
    grid.innerHTML=render.map(function(p){
      return '<a href="'+p.url+'" style="text-decoration:none;display:block;">'
        +'<div style="aspect-ratio:4/5;overflow:hidden;border-radius:3px;background:var(--rv-bone-2);margin-bottom:12px;">'
        +(p.image?'<img src="'+p.image+'" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;">':'')
        +'</div>'
        +'<div style="font:500 14px/1.3 var(--rv-sans);color:var(--rv-char);margin-bottom:3px;">'+p.title+'</div>'
        +(p.material?'<div style="font-family:var(--rv-serif);font-style:italic;font-size:14px;color:var(--rv-grey);margin-bottom:4px;">'+p.material+'</div>':'')
        +'<div style="font:600 13px/1 var(--rv-sans);color:var(--rv-char);">'+p.price+'</div></a>';
    }).join('');
    sec.style.display='';
  }
  // record current at front
  list.unshift(current);
  var seen={},dedup=[];
  list.forEach(function(p){if(p&&!seen[p.handle]){seen[p.handle]=1;dedup.push(p);}});
  try{localStorage.setItem(KEY,JSON.stringify(dedup.slice(0,12)));}catch(e){}
})();
</script>
<style>
@media(max-width:768px){[data-rv-recent-grid]{grid-template-columns:repeat(2,1fr)!important;}}
</style>
{% schema %}{"name":"Recently Viewed","tag":"section","settings":[
{"type":"text","id":"heading","label":"Heading","default":"Recently viewed"}
],"presets":[{"name":"Recently Viewed"}]}{% endschema %}