{%- assign style = section.settings.hero_style -%}
{%- if style == 'fullbleed' -%}

<section class="rv-hero rv-hero--fullbleed" style="position:relative;overflow:hidden;">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'rv-hero__bg-img', style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;', alt: section.settings.image.alt }}
  {%- else -%}
    <div style="position:absolute;inset:0;background:var(--rv-deep);"></div>
  {%- endif -%}
  <div style="position:absolute;inset:0;background:rgba(43,42,39,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
  <div class="rv-hero__fullbleed-content">
    <p class="rv-eyebrow rv-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="rv-hero__title rv-hero__title--light">{{ section.settings.heading }}</h1>
    <p class="rv-hero__sub rv-hero__sub--light">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.cta_url }}" class="rv-btn rv-btn--primary rv-hero__cta">{{ section.settings.cta_label }}</a>
    {%- if section.settings.trust_line != blank -%}
      <div class="rv-hero__trust rv-hero__trust--light">
        <span class="rv-stars">★★★★★</span>
        <span>{{ section.settings.trust_line }}</span>
      </div>
    {%- endif -%}
  </div>
</section>

{%- else -%}

<section class="rv-hero rv-hero--split">
  <div class="rv-hero__split-inner">
    <!-- Text column -->
    <div class="rv-hero__text">
      <p class="rv-eyebrow rv-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      <h1 class="rv-hero__title">{{ section.settings.heading }}</h1>
      <p class="rv-hero__sub">{{ section.settings.subheading }}</p>
      <div class="rv-hero__cta-row">
        <a href="{{ section.settings.cta_url }}" class="rv-btn rv-btn--primary rv-hero__cta">{{ section.settings.cta_label }}</a>
        {%- if section.settings.trust_line != blank -%}
          <div class="rv-hero__trust">
            <span class="rv-stars" style="font-size:14px;">★★★★★</span>
            <span>{{ section.settings.trust_line }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
    <!-- Image column -->
    <div class="rv-hero__img-col">
      <!-- gradient scrim (hidden on desktop, visible on mobile) -->
      <div class="rv-hero__scrim"></div>
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'eager', fetchpriority: 'high', class: 'rv-hero__img', alt: section.settings.image.alt }}
      {%- else -%}
        <div class="rv-hero__img-placeholder">{{ 'product-1' | placeholder_svg_tag: 'rv-placeholder-svg' }}</div>
      {%- endif -%}
      {%- if section.settings.inset_image != blank -%}
        <div class="rv-hero__inset">
          {{ section.settings.inset_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: section.settings.inset_image.alt }}
        </div>
      {%- endif -%}
      {%- if section.settings.badge_text != blank -%}
        <div class="rv-hero__badge">{{ section.settings.badge_text }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{%- endif -%}

<style>
/* ═══════════════════════════════════════════════════════════════
   HERO — shared
═══════════════════════════════════════════════════════════════ */
.rv-hero { background: var(--rv-bone); }

/* ── Full-bleed hero ─────────────────────────────────────────── */
.rv-hero--fullbleed {
  height: {{ section.settings.height_px }}px;
  min-height: 480px;
  display: flex; align-items: center; justify-content: center;
}
.rv-hero__fullbleed-content {
  position: relative; text-align: center;
  color: #FBF9F4; padding: 0 24px; max-width: 960px; z-index: 2;
}

/* ── Split hero — desktop ────────────────────────────────────── */
.rv-hero--split { }
.rv-hero__split-inner {
  max-width: 1320px; margin: 0 auto;
  padding: 56px 32px 72px;
  display: grid; grid-template-columns: 1.1fr 1fr; gap: 56px;
  align-items: center;
}
.rv-hero__eyebrow { color: var(--rv-grey-2); }
.rv-hero__title {
  font-family: var(--rv-serif); font-weight: 500;
  font-size: clamp(40px, 4.6vw, 72px);
  line-height: 1.06; letter-spacing: -.015em;
  color: var(--rv-char); margin: 0;
}
.rv-hero__title--light { color: #FBF9F4; font-size: clamp(40px, 5.5vw, 88px); line-height: 1.04; }
.rv-hero__sub {
  font: 400 17px/1.6 var(--rv-sans);
  color: var(--rv-soft); max-width: 440px; margin: 26px 0 34px;
}
.rv-hero__sub--light { color: rgba(251,249,244,.92); max-width: 540px; margin: 22px auto 34px; }
.rv-hero__cta-row { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
.rv-hero__trust {
  display: flex; flex-direction: column; gap: 4px;
  font: 400 12px/1 var(--rv-sans); color: var(--rv-soft);
}
.rv-hero__trust--light { color: rgba(251,249,244,.9); flex-direction: row; gap: 10px; align-items: center; margin-top: 18px; justify-content: center; }
.rv-hero__img-col { position: relative; }
.rv-hero__img { width: 100%; height: 520px; object-fit: cover; border-radius: 4px; display: block; }
.rv-hero__img-placeholder { width: 100%; height: 520px; background: var(--rv-bone-2); border-radius: 4px; display: flex; align-items: center; justify-content: center; }
.rv-hero__inset img { width: 210px; height: 260px; object-fit: cover; border-radius: 4px; position: absolute; bottom: -28px; left: -36px; border: 8px solid var(--rv-bone); box-shadow: 0 24px 50px -22px rgba(43,42,39,.4); }
.rv-hero__badge { position: absolute; top: 22px; right: 22px; background: rgba(251,249,244,.92); backdrop-filter: blur(4px); padding: 10px 14px; border-radius: 2px; font: 600 11px/1 var(--rv-sans); letter-spacing: .14em; text-transform: uppercase; color: var(--rv-char); }
.rv-hero__scrim { display: none; }

/* ═══════════════════════════════════════════════════════════════
   MOBILE HERO — full-viewport, dominant (approved)
═══════════════════════════════════════════════════════════════ */
@media(max-width: 1024px) {

  /* Full-bleed: use svh */
  .rv-hero--fullbleed {
    height: 100svh !important;
    height: 100vh !important;
    min-height: 580px !important;
    max-height: 800px !important;
  }

  /* Split: collapse to full-bleed image + text overlay */
  .rv-hero--split { position: relative; }
  .rv-hero__split-inner {
    display: block !important;
    padding: 0 !important;
    gap: 0 !important;
    max-width: none !important;
  }

  /* Image col fills full screen */
  .rv-hero__img-col {
    position: relative !important;
    width: 100% !important;
    height: 100svh !important;
    height: 100vh !important;
    min-height: 580px !important;
    max-height: 800px !important;
  }
  .rv-hero__img {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    border-radius: 0 !important;
  }
  .rv-hero__img-placeholder {
    position: absolute !important;
    inset: 0 !important;
    height: 100% !important;
    border-radius: 0 !important;
  }

  /* Gradient scrim over image */
  .rv-hero__scrim {
    display: block !important;
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(175deg, rgba(43,42,39,.04) 0%, rgba(43,42,39,.18) 40%, rgba(43,42,39,.84) 100%) !important;
    z-index: 2 !important;
    pointer-events: none !important;
  }

  /* Text column: pinned to bottom of image col */
  .rv-hero__text {
    position: absolute !important;
    bottom: 0 !important; left: 0 !important; right: 0 !important;
    z-index: 3 !important;
    padding: 0 20px 28px !important;
  }
  .rv-hero__eyebrow { color: var(--rv-butter) !important; }
  .rv-hero__title {
    font-size: clamp(36px, 10vw, 52px) !important;
    color: #FBF9F4 !important;
    text-shadow: 0 2px 24px rgba(43,42,39,.3) !important;
  }
  .rv-hero__sub {
    color: rgba(251,249,244,.88) !important;
    font-size: 14px !important;
    margin: 12px 0 18px !important;
    max-width: none !important;
  }
  .rv-hero__cta-row { flex-direction: column !important; gap: 14px !important; align-items: stretch !important; }
  .rv-hero__cta { width: 100% !important; justify-content: center !important; height: 52px !important; }
  .rv-hero__trust { flex-direction: row !important; align-items: center !important; gap: 8px !important; color: rgba(251,249,244,.88) !important; }

  /* Hide inset image on mobile */
  .rv-hero__inset { display: none !important; }

  /* Badge — reposition */
  .rv-hero__badge {
    top: 16px !important; right: 16px !important;
    background: rgba(251,249,244,.92) !important;
    backdrop-filter: blur(6px) !important;
    z-index: 4 !important;
  }
}
</style>

{% schema %}{"name":"Hero Banner","tag":"section","settings":[
{"type":"select","id":"hero_style","label":"Hero style","options":[{"value":"split","label":"Split – editorial (desktop)"},{"value":"fullbleed","label":"Full-bleed – beauty"}],"default":"split"},
{"type":"image_picker","id":"image","label":"Hero image"},
{"type":"image_picker","id":"inset_image","label":"Inset image (desktop split only)"},
{"type":"range","id":"height_px","label":"Full-bleed height (desktop, px)","min":400,"max":900,"step":20,"default":680},
{"type":"range","id":"overlay_opacity","label":"Dark overlay %","min":0,"max":80,"step":5,"default":40},
{"type":"text","id":"eyebrow","label":"Eyebrow text","default":"Curated beauty & elegant essentials"},
{"type":"text","id":"heading","label":"Headline","default":"Beauty. Organization. Everyday luxury."},
{"type":"textarea","id":"subheading","label":"Subheading","default":"Curated beauty, skincare and elegant essentials designed to elevate your daily rituals."},
{"type":"text","id":"cta_label","label":"Button label","default":"Shop Best Sellers"},
{"type":"url","id":"cta_url","label":"Button link"},
{"type":"text","id":"trust_line","label":"Trust line under CTA","default":"4.8 · 12,400+ reviews"},
{"type":"text","id":"badge_text","label":"Corner badge","default":"New · Vanity Edit"}
],"presets":[{"name":"Hero Banner"}]}{% endschema %}