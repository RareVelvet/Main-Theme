{%- comment -%} RV-TYPE-GUARD: renders only for matching product types {%- endcomment -%}
{%- assign rvt = product.type | downcase -%}
{%- assign rv_render = false -%}
{%- if rvt contains 'device' or rvt contains 'tool' -%}{%- assign rv_render = true -%}{%- endif -%}
{%- if rv_render -%}

<section class="rv-pdp-band">
  <div class="rv-pdp-band__inner">
    <div style="text-align:center;margin-bottom:48px;">
      <p class="rv-eyebrow" style="color:var(--rv-butter);">{{ section.settings.eyebrow }}</p>
      <h2 class="rv-heading rv-heading--light">{{ section.settings.heading }}</h2>
    </div>
    <div class="rv-grid-3" style="margin-bottom:56px;">
      {%- for block in section.blocks -%}
        <div class="rv-pdp-stat" {{ block.shopify_attributes }}>
          <div class="rv-pdp-stat__num">{{ block.settings.stat }}</div>
          <div class="rv-pdp-stat__label">{{ block.settings.label }}</div>
          <p class="rv-pdp-stat__desc">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.before_image != blank or section.settings.after_image != blank -%}
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;border-radius:4px;overflow:hidden;max-width:860px;margin:0 auto;">
        <div style="position:relative;">
          {%- if section.settings.before_image != blank -%}
            {{ section.settings.before_image | image_url: width: 700 | image_tag: loading: 'lazy', style: 'width:100%;height:420px;object-fit:cover;display:block;', alt: 'Before' }}
          {%- else -%}
            <div class="rv-placeholder-img" style="height:420px;">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
          <span style="position:absolute;bottom:14px;left:14px;background:rgba(43,42,39,.8);color:var(--rv-bone);font:600 11px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;padding:7px 12px;border-radius:999px;">Before</span>
        </div>
        <div style="position:relative;">
          {%- if section.settings.after_image != blank -%}
            {{ section.settings.after_image | image_url: width: 700 | image_tag: loading: 'lazy', style: 'width:100%;height:420px;object-fit:cover;display:block;', alt: 'After' }}
          {%- else -%}
            <div class="rv-placeholder-img" style="height:420px;">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
          <span style="position:absolute;bottom:14px;left:14px;background:var(--rv-butter);color:var(--rv-char);font:600 11px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;padding:7px 12px;border-radius:999px;">After</span>
        </div>
      </div>
    {%- endif -%}
    {%- if section.settings.disclaimer != blank -%}
      <p style="font:400 11px/1.5 var(--rv-sans);color:var(--rv-deep-soft);text-align:center;margin-top:20px;max-width:700px;margin-left:auto;margin-right:auto;">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>

{%- endif -%}
{% schema %}{"name":"Device Results","tag":"section","max_blocks":4,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Clinically tested results"},
{"type":"text","id":"heading","label":"Heading","default":"Visible results in 4 weeks"},
{"type":"image_picker","id":"before_image","label":"Before image"},
{"type":"image_picker","id":"after_image","label":"After image"},
{"type":"textarea","id":"disclaimer","label":"Clinical disclaimer"}
],"blocks":[{"type":"stat","name":"Clinical stat","settings":[
{"type":"text","id":"stat","label":"Statistic","default":"93%"},
{"type":"text","id":"label","label":"Label","default":"reported firmer skin"},
{"type":"textarea","id":"description","label":"Description","default":"In an 8-week independent clinical study."}
]}],"presets":[{"name":"Device Results","blocks":[{"type":"stat","settings":{"stat":"93%","label":"reported firmer skin"}},{"type":"stat","settings":{"stat":"87%","label":"noticed reduced lines"}},{"type":"stat","settings":{"stat":"4 weeks","label":"average for visible results"}}]}]}{% endschema %}