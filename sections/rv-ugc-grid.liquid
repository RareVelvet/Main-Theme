
<section class="rv-section">
  <div class="rv-container">
    <div style="text-align:center;margin-bottom:30px;">
      <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="rv-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.handle != blank -%}
        <a href="https://instagram.com/{{ section.settings.handle | remove: '@' }}" target="_blank" rel="noopener" class="rv-ugc-follow">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          <span>{{ section.settings.handle }}</span>
          <span class="rv-ugc-follow__btn">Follow</span>
        </a>
      {%- endif -%}
    </div>

    {%- if section.settings.use_instafeed -%}
      {%- comment -%}
        Instafeed live Instagram grid. Add the Instafeed app block here in the Theme Editor,
        OR paste the app's embed/snippet into the "Instafeed embed code" setting.
      {%- endcomment -%}
      {%- if section.settings.instafeed_code != blank -%}
        <div class="rv-ugc-instafeed">{{ section.settings.instafeed_code }}</div>
      {%- else -%}
        <div class="rv-ugc-instafeed" id="instafeed">
          {%- comment -%} Instafeed.js / app target. If empty, falls back to manual photos below. {%- endcomment -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="rv-ugc-grid">
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <a href="{{ block.settings.product.url }}" class="rv-ugc-cell rv-ugc-cell--shop" {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="rv-ugc-cell" {{ block.shopify_attributes }}>
          {%- endif -%}
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'rv-ugc-img', alt: block.settings.image.alt }}
            {%- else -%}
              <div class="rv-ugc-img rv-placeholder-img rv-ugc-placeholder">{{ 'image' | placeholder_svg_tag }}</div>
            {%- endif -%}
            {%- if block.settings.is_video -%}
              <div class="rv-ugc-play-overlay"><span class="rv-ugc-play-btn">▶</span></div>
              <span class="rv-ugc-reel-badge">Reel</span>
            {%- endif -%}
            {%- if block.settings.product != blank -%}
              <div class="rv-ugc-shop"><span class="rv-ugc-shop__name">{{ block.settings.product.title }}</span><span class="rv-ugc-shop__cta">Shop →</span></div>
            {%- else -%}
              <span class="rv-ugc-ig"><svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><path d="M12 2c2.7 0 3 0 4.1.1 1 0 1.7.2 2.3.4.6.3 1.1.6 1.6 1.1s.8 1 1.1 1.6c.2.6.4 1.3.4 2.3.1 1.1.1 1.4.1 4.1s0 3-.1 4.1c0 1-.2 1.7-.4 2.3-.3.6-.6 1.1-1.1 1.6s-1 .8-1.6 1.1c-.6.2-1.3.4-2.3.4-1.1.1-1.4.1-4.1.1s-3 0-4.1-.1c-1 0-1.7-.2-2.3-.4-.6-.3-1.1-.6-1.6-1.1s-.8-1-1.1-1.6c-.2-.6-.4-1.3-.4-2.3C2 15 2 14.7 2 12s0-3 .1-4.1c0-1 .2-1.7.4-2.3.3-.6.6-1.1 1.1-1.6s1-.8 1.6-1.1c.6-.2 1.3-.4 2.3-.4C9 2 9.3 2 12 2zm0 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.2a3.2 3.2 0 1 1 0-6.4 3.2 3.2 0 0 1 0 6.4zm5.2-8.4a1.2 1.2 0 1 0 0-2.4 1.2 1.2 0 0 0 0 2.4z"/></svg></span>
            {%- endif -%}
          {%- if block.settings.product != blank -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.quote != blank -%}
      <div style="text-align:center;max-width:620px;margin:48px auto 0;">
        <div class="rv-stars" style="font-size:16px;margin-bottom:14px;">★★★★★</div>
        <p style="font-family:var(--rv-serif);font-style:italic;font-size:clamp(20px,2.4vw,28px);line-height:1.35;color:var(--rv-char);margin:0;">"{{ section.settings.quote }}"</p>
        <div style="font:500 12px/1 var(--rv-sans);letter-spacing:.14em;text-transform:uppercase;color:var(--rv-soft);margin-top:18px;">{{ section.settings.quote_author }}</div>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.rv-ugc-follow{display:inline-flex;align-items:center;gap:9px;margin-top:14px;font:500 13px/1 var(--rv-sans);color:var(--rv-char);text-decoration:none;}
.rv-ugc-follow__btn{font:600 10px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;background:var(--rv-char);color:var(--rv-bone);padding:7px 12px;border-radius:999px;margin-left:4px;}
.rv-ugc-instafeed{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
.rv-ugc-instafeed img{width:100%;aspect-ratio:1/1;object-fit:cover;display:block;border-radius:3px;}
.rv-ugc-cell{position:relative;}
.rv-ugc-cell--shop{display:block;text-decoration:none;cursor:pointer;}
.rv-ugc-shop{position:absolute;bottom:12px;left:12px;right:12px;display:flex;align-items:center;justify-content:space-between;gap:8px;background:rgba(251,249,244,.94);backdrop-filter:blur(4px);padding:9px 12px;border-radius:2px;}
.rv-ugc-shop__name{font:500 12px/1.2 var(--rv-sans);color:var(--rv-char);}
.rv-ugc-shop__cta{font:600 11px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;color:var(--rv-char);white-space:nowrap;}
.rv-ugc-ig{position:absolute;top:10px;right:10px;opacity:.85;}
@media(max-width:768px){
  .rv-ugc-instafeed{display:flex;overflow-x:auto;gap:10px;scroll-snap-type:x mandatory;scrollbar-width:none;}
  .rv-ugc-instafeed::-webkit-scrollbar{display:none}
  .rv-ugc-instafeed > *{flex:none;width:62vw;scroll-snap-align:start;}
}
</style>

{% schema %}{"name":"Customer Photos","tag":"section","max_blocks":8,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"@rarevelvet"},
{"type":"text","id":"heading","label":"Heading","default":"Loved & shared by our community"},
{"type":"text","id":"handle","label":"Instagram handle (shows Follow button)","default":"@rarevelvet"},
{"type":"header","content":"Instafeed (live Instagram)"},
{"type":"checkbox","id":"use_instafeed","label":"Use live Instagram feed (Instafeed)","info":"On: shows your live IG grid. Add the Instafeed app block in the editor, or paste its embed below. Off: uses the manual photos.","default":true},
{"type":"liquid","id":"instafeed_code","label":"Instafeed embed code","info":"Paste the snippet from the Instafeed app, or leave blank to use the app's #instafeed target / app block."},
{"type":"text","id":"quote","label":"Featured review quote"},
{"type":"text","id":"quote_author","label":"Quote author","default":"Maya R. · Verified buyer"}
],"blocks":[{"type":"photo","name":"Photo or reel","settings":[
{"type":"image_picker","id":"image","label":"Image"},
{"type":"product","id":"product","label":"Shoppable product (optional)","info":"Link this photo to a product — shows a Shop cue."},
{"type":"checkbox","id":"is_video","label":"Show video play overlay","default":false}
]}],"presets":[{"name":"Customer Photos","blocks":[
{"type":"photo","settings":{"is_video":true}},{"type":"photo"},{"type":"photo"},{"type":"photo"}
]}]}{% endschema %}
