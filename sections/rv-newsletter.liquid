
<section style="background:var(--rv-caramel);">
  <div style="max-width:720px;margin:0 auto;padding:76px 32px;text-align:center;">
    <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(32px,4vw,52px);line-height:1.04;color:var(--rv-char);margin:0 0 14px;">{{ section.settings.heading }}</h2>
    <p style="font:400 15px/1.6 var(--rv-sans);color:var(--rv-soft);margin:0 auto 30px;max-width:400px;">{{ section.settings.subheading }}</p>
    {%- form 'customer', id: 'rv-nl-form', data-newsletter-form: '' -%}
      <input type="hidden" name="contact[tags]" value="newsletter,prospect">
      <div class="rv-newsletter__form">
        <input class="rv-newsletter__input" type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" autocomplete="email" required>
        <button type="submit" class="rv-btn rv-btn--primary">{{ section.settings.btn_label }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="rv-newsletter__msg">{{ section.settings.success_msg }}</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="rv-newsletter__msg" style="color:red;">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>
{% schema %}{"name":"Newsletter","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Join the list"},
{"type":"text","id":"heading","label":"Heading","default":"Get 10% off your first order"},
{"type":"textarea","id":"subheading","label":"Subheading","default":"Be first to new edits, restocks and members-only offers."},
{"type":"text","id":"placeholder","label":"Input placeholder","default":"Email address"},
{"type":"text","id":"btn_label","label":"Button label","default":"Subscribe"},
{"type":"text","id":"success_msg","label":"Success message","default":"Thank you! Check your inbox for 10% off."}
],"presets":[{"name":"Newsletter"}]}{% endschema %}