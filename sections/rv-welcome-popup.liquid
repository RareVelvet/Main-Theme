
{%- if section.settings.enable -%}
<div class="rv-welcome" data-rv-welcome data-delay="{{ section.settings.delay_seconds }}" aria-hidden="true">
  <div class="rv-welcome__scrim" data-rv-welcome-close></div>
  <div class="rv-welcome__card" role="dialog" aria-modal="true" aria-label="{{ section.settings.heading | escape }}">
    <button class="rv-welcome__close" data-rv-welcome-close aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    {%- if section.settings.image != blank -%}
      <div class="rv-welcome__media">{{ section.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: '' }}</div>
    {%- endif -%}
    <div class="rv-welcome__body">
      <div class="rv-welcome__eyebrow">{{ section.settings.eyebrow }}</div>
      <h2 class="rv-welcome__heading">{{ section.settings.heading }}</h2>
      <p class="rv-welcome__sub">{{ section.settings.subtext }}</p>
      {%- form 'customer', id: 'rv-welcome-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,welcome-popup">
        {%- if form.posted_successfully? -%}
          {%- assign rv_posted = true -%}
          <p class="rv-welcome__success">{{ section.settings.success_text }}</p>
        {%- else -%}
          <div class="rv-welcome__field">
            <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" autocomplete="email" required>
            <button type="submit">{{ section.settings.button_label }}</button>
          </div>
        {%- endif -%}
      {%- endform -%}
      <button class="rv-welcome__decline" data-rv-welcome-close>{{ section.settings.decline_label }}</button>
    </div>
  </div>
</div>

<style>
.rv-welcome{position:fixed;inset:0;z-index:340;visibility:hidden;}
.rv-welcome.is-open{visibility:visible;}
.rv-welcome__scrim{position:absolute;inset:0;background:rgba(43,42,39,.42);opacity:0;transition:opacity .35s ease;}
.rv-welcome.is-open .rv-welcome__scrim{opacity:1;}
.rv-welcome__card{position:absolute;top:50%;left:50%;transform:translate(-50%,-46%);opacity:0;transition:opacity .4s ease,transform .4s cubic-bezier(.2,.7,.2,1);width:680px;max-width:92vw;background:var(--rv-bone);border-radius:4px;overflow:hidden;display:grid;grid-template-columns:1fr 1fr;box-shadow:0 40px 90px -30px rgba(43,42,39,.5);}
.rv-welcome.is-open .rv-welcome__card{opacity:1;transform:translate(-50%,-50%);}
.rv-welcome__media{position:relative;}
.rv-welcome__media img{width:100%;height:100%;object-fit:cover;display:block;}
.rv-welcome__body{padding:40px 36px;display:flex;flex-direction:column;justify-content:center;position:relative;}
.rv-welcome__close{position:absolute;top:14px;right:14px;background:none;border:none;cursor:pointer;color:var(--rv-char);z-index:2;display:flex;}
.rv-welcome__eyebrow{font:600 11px/1 var(--rv-sans);letter-spacing:.18em;text-transform:uppercase;color:var(--rv-clay);margin-bottom:14px;}
.rv-welcome__heading{font-family:var(--rv-serif);font-weight:500;font-size:clamp(28px,3vw,38px);line-height:1.05;color:var(--rv-char);margin:0 0 12px;}
.rv-welcome__sub{font:400 14px/1.6 var(--rv-sans);color:var(--rv-soft);margin:0 0 22px;}
.rv-welcome__field{display:flex;flex-direction:column;gap:10px;}
.rv-welcome__field input{border:1px solid var(--rv-line);border-radius:2px;padding:14px 16px;font:400 15px/1 var(--rv-sans);background:var(--rv-paper);color:var(--rv-char);outline:none;}
.rv-welcome__field button{background:var(--rv-clay);color:#FBF9F4;border:none;cursor:pointer;font:600 12px/1 var(--rv-sans);letter-spacing:.14em;text-transform:uppercase;padding:15px;border-radius:2px;transition:opacity .2s;}
.rv-welcome__field button:hover{opacity:.9;}
.rv-welcome__success{font:500 15px/1.5 var(--rv-sans);color:var(--rv-char);}
.rv-welcome__decline{background:none;border:none;cursor:pointer;font:400 12px/1 var(--rv-sans);color:var(--rv-grey-2);text-decoration:underline;margin-top:16px;align-self:flex-start;padding:0;}
@media(max-width:640px){
  .rv-welcome__card{grid-template-columns:1fr;width:420px;}
  .rv-welcome__media{display:none;}
  .rv-welcome__body{padding:34px 26px;}
}
</style>

<script>
(function(){
  var root=document.querySelector('[data-rv-welcome]');
  if(!root)return;
  var KEY='rv_welcome_seen';
  var posted={% if rv_posted %}true{% else %}false{% endif %};
  function open(){root.classList.add('is-open');root.setAttribute('aria-hidden','false');}
  function close(){root.classList.remove('is-open');root.setAttribute('aria-hidden','true');try{localStorage.setItem(KEY,Date.now());}catch(e){}}
  root.querySelectorAll('[data-rv-welcome-close]').forEach(function(el){el.addEventListener('click',close);});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&root.classList.contains('is-open'))close();});
  if(posted){open();return;}
  var seen=false;try{seen=!!localStorage.getItem(KEY);}catch(e){}
  if(seen)return;
  var delay=(parseInt(root.getAttribute('data-delay'),10)||4)*1000;
  setTimeout(open,delay);
})();
</script>
{%- endif -%}
{% schema %}{"name":"Welcome Popup","tag":"div","settings":[
{"type":"checkbox","id":"enable","label":"Enable popup","info":"For advanced targeting (exit-intent, segments) use Shopify Forms or Klaviyo instead.","default":false},
{"type":"range","id":"delay_seconds","label":"Show after (seconds)","min":1,"max":20,"step":1,"default":4},
{"type":"image_picker","id":"image","label":"Image"},
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Welcome to Rare Velvet"},
{"type":"text","id":"heading","label":"Heading","default":"10% off your first order"},
{"type":"textarea","id":"subtext","label":"Subtext","default":"Join the list for 10% off, plus first access to new edits, restocks and members-only offers."},
{"type":"text","id":"placeholder","label":"Input placeholder","default":"Enter your email"},
{"type":"text","id":"button_label","label":"Button label","default":"Get my 10% off"},
{"type":"text","id":"decline_label","label":"Decline label","default":"No thanks, I’ll pay full price"},
{"type":"text","id":"success_text","label":"Success message","default":"You’re in — check your inbox for your code."}
]}{% endschema %}
