
<section class="rv-pdp-band">
  <div class="rv-pdp-band__inner">
    <div class="rv-pdp-split" style="grid-template-columns:1.1fr 1fr;">
      <div>
        <p class="rv-eyebrow" style="color:var(--rv-butter);">{{ section.settings.eyebrow }}</p>
        <h2 class="rv-heading rv-heading--light" style="margin-bottom:28px;">{{ section.settings.heading }}</h2>
        {%- for block in section.blocks -%}
          <div class="rv-pdp-detail" {{ block.shopify_attributes }}>
            <div class="rv-pdp-detail__icon"><span style="border-radius:{{ block.settings.dot_shape }};"></span></div>
            <div>
              <div class="rv-pdp-detail__title">{{ block.settings.title }}</div>
              <div class="rv-pdp-detail__desc">{{ block.settings.description }}</div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      <div>
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', style: 'width:100%;height:500px;object-fit:cover;border-radius:4px;display:block;', alt: section.settings.image.alt }}
        {%- else -%}
          <div class="rv-placeholder-img" style="height:500px;border-radius:4px;">{{ 'product-2' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Product Details","tag":"section","max_blocks":5,"settings":[
{"type":"image_picker","id":"image","label":"Detail image"},
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"The details"},
{"type":"text","id":"heading","label":"Heading","default":"Crafted to be kept"}
],"blocks":[{"type":"detail","name":"Detail item","settings":[
{"type":"text","id":"title","label":"Title","default":"Materials"},
{"type":"textarea","id":"description","label":"Description","default":"Cotton velvet, FSC-certified wood frame, brushed brass."},
{"type":"select","id":"dot_shape","label":"Icon shape","options":[{"value":"999px","label":"Circle"},{"value":"3px","label":"Square"},{"value":"50% 50% 50% 0","label":"Teardrop"}],"default":"3px"}
]}],"presets":[{"name":"Product Details","blocks":[{"type":"detail","settings":{"title":"Materials"}},{"type":"detail","settings":{"title":"Dimensions"}},{"type":"detail","settings":{"title":"Care"}}]}]}{% endschema %}