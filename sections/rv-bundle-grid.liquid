
<section class="rv-section">
  <div class="rv-container">
    <div class="rv-section-head">
      <div>
        <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="rv-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.all_url != blank -%}
        <a href="{{ section.settings.all_url }}" class="rv-view-all">Shop bundles →</a>
      {%- endif -%}
    </div>
    <div class="rv-grid-4">
      {%- for block in section.blocks -%}
        <div class="rv-card" {{ block.shopify_attributes }}>
          <div class="rv-card__img" style="overflow:hidden;position:relative;">
            {%- if block.settings.image != blank -%}
              {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
              <div style="aspect-ratio:1/1;overflow:hidden;width:100%;">
                {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy',
                  style: 'width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.2,.7,.2,1);',
                  alt: block.settings.title }}
              </div>
              {%- if block.settings.link != blank -%}</a>{%- endif -%}
            {%- elsif block.settings.product != blank -%}
              {%- assign bp = all_products[block.settings.product] -%}
              <a href="{{ bp.url }}">
                <div style="aspect-ratio:1/1;overflow:hidden;width:100%;">
                  {%- if bp.featured_image -%}
                    {{ bp.featured_image | image_url: width: 700 | image_tag: loading: 'lazy',
                      style: 'width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.2,.7,.2,1);',
                      alt: bp.title }}
                  {%- else -%}
                    <div class="rv-placeholder-img" style="width:100%;height:100%;">{{ 'product-2' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                </div>
              </a>
            {%- else -%}
              <div style="aspect-ratio:1/1;overflow:hidden;width:100%;">
                <div class="rv-placeholder-img" style="width:100%;height:100%;">{{ 'product-2' | placeholder_svg_tag }}</div>
              </div>
            {%- endif -%}
            <span class="rv-card__badge rv-badge rv-badge--dark">{{ block.settings.badge }}</span>
          </div>
          <div class="rv-card__body">
            <div style="font-family:var(--rv-serif);font-size:21px;color:var(--rv-char);font-weight:500;margin-bottom:6px;">{{ block.settings.title }}</div>
            <p style="font:400 13px/1.5 var(--rv-sans);color:var(--rv-soft);margin:0 0 14px;">{{ block.settings.description }}</p>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <span style="font:600 14px/1 var(--rv-sans);color:var(--rv-char);">
                {{ block.settings.price }}
                <span style="font-weight:400;color:var(--rv-grey-2);text-decoration:line-through;font-size:12px;margin-left:4px;">{{ block.settings.price_was }}</span>
              </span>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" style="font:400 12px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;color:var(--rv-char);border-bottom:1px solid var(--rv-butter-2);padding-bottom:2px;">Add set →</a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{"name":"Bundle Grid","tag":"section","max_blocks":4,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Curated together · save more"},
{"type":"text","id":"heading","label":"Heading","default":"Featured bundles"},
{"type":"url","id":"all_url","label":"View all link"}
],"blocks":[{"type":"bundle","name":"Bundle card","settings":[
{"type":"product","id":"product","label":"Link to Shopify product (auto-pulls image)"},
{"type":"image_picker","id":"image","label":"Custom image (overrides product image — always same-size card)"},
{"type":"text","id":"title","label":"Bundle name","default":"Night Routine Bundle"},
{"type":"textarea","id":"description","label":"Description","default":"Cleanser, night serum & silk eye mask."},
{"type":"text","id":"price","label":"Bundle price","default":"$76"},
{"type":"text","id":"price_was","label":"Was price","default":"$94"},
{"type":"text","id":"badge","label":"Badge text","default":"Save $18"},
{"type":"url","id":"link","label":"Link"}
]}],"presets":[{"name":"Bundle Grid","blocks":[
{"type":"bundle","settings":{"title":"Night Routine Bundle","badge":"Save $18"}},
{"type":"bundle","settings":{"title":"Travel Essentials Set","badge":"3-in-1"}},
{"type":"bundle","settings":{"title":"Self-Care Bundle","badge":"Save $14"}},
{"type":"bundle","settings":{"title":"Beauty Lover Gift Set","badge":"Gift Set"}}
]}]}{% endschema %}