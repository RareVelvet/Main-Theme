
{%- if section.settings.show -%}
<div class="rv-announcement" style="background:{{ section.settings.bg }};color:{{ section.settings.fg }};" data-rv-announce>
  {%- assign msg_count = 0 -%}
  {%- for block in section.blocks -%}{%- if block.type == 'message' -%}{%- assign msg_count = msg_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
  {%- if msg_count > 0 -%}
    <div class="rv-announce-track" data-rv-announce-track>
      {%- for block in section.blocks -%}
        {%- if block.type == 'message' -%}
          <div class="rv-announce-slide" data-rv-announce-slide {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" style="color:inherit;text-decoration:none;">{%- endif -%}
            {{ block.settings.text }}
            {%- if block.settings.link != blank -%}</a>{%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    {%- if section.settings.link != blank -%}<a href="{{ section.settings.link }}" style="color:inherit;text-decoration:none;">{%- endif -%}
    {{ section.settings.text }}
    {%- if section.settings.link != blank -%}</a>{%- endif -%}
  {%- endif -%}
</div>

{%- if msg_count > 1 -%}
<style>
.rv-announcement[data-rv-announce]{overflow:hidden;}
.rv-announce-slide{display:none;}
.rv-announce-slide.is-active{display:block;animation:rvAnnounceIn .5s ease;}
@keyframes rvAnnounceIn{from{opacity:0;transform:translateY(-4px);}to{opacity:1;transform:none;}}
</style>
<script>
(function(){
  var track=document.querySelector('[data-rv-announce-track]');
  if(!track)return;
  var slides=track.querySelectorAll('[data-rv-announce-slide]');
  if(slides.length<2){if(slides[0])slides[0].classList.add('is-active');return;}
  var i=0;slides[0].classList.add('is-active');
  var delay={{ section.settings.rotate_seconds | default: 4 | times: 1000 }};
  setInterval(function(){
    slides[i].classList.remove('is-active');
    i=(i+1)%slides.length;
    slides[i].classList.add('is-active');
  },delay);
})();
</script>
{%- elsif msg_count == 1 -%}
<style>.rv-announce-slide{display:block;}</style>
{%- endif -%}
{%- endif -%}
{% schema %}{"name":"Announcement Bar","tag":"section","max_blocks":6,"settings":[
{"type":"checkbox","id":"show","label":"Show bar","default":true},
{"type":"range","id":"rotate_seconds","label":"Rotate every (seconds)","min":2,"max":10,"step":1,"default":4},
{"type":"color","id":"bg","label":"Background","default":"#2B2A27"},
{"type":"color","id":"fg","label":"Text colour","default":"#F4F1EA"},
{"type":"header","content":"Fallback (used only if no messages added below)"},
{"type":"text","id":"text","label":"Text","default":"Complimentary shipping over $50 · Lifetime warranty on jewelry boxes"},
{"type":"url","id":"link","label":"Link (optional)"}
],"blocks":[{"type":"message","name":"Message","settings":[
{"type":"text","id":"text","label":"Text","default":"Complimentary shipping over $50"},
{"type":"url","id":"link","label":"Link (optional)"}
]}],"presets":[{"name":"Announcement Bar","blocks":[
{"type":"message","settings":{"text":"Complimentary shipping over $50"}},
{"type":"message","settings":{"text":"Free 30-day returns on every order"}},
{"type":"message","settings":{"text":"Earn Rare Velvet points on every purchase"}}
]}]}{% endschema %}
