{%- comment -%} RV-TYPE-GUARD: renders only for matching product types {%- endcomment -%}
{%- assign rvt = product.type | downcase -%}
{%- assign rv_render = false -%}
{%- if rvt contains 'lounge' or rvt contains 'fashion' or rvt contains 'apparel' or rvt contains 'clothing' or rvt contains 'wear' or rvt contains 'coat' or rvt contains 'slipper' -%}{%- assign rv_render = true -%}{%- endif -%}
{%- if rv_render -%}

{%- comment -%} Style it with — auto-pulls from a collection (Lounge), excludes current product {%- endcomment -%}
{%- assign source = collections[section.settings.collection] -%}
{%- if source == blank and product.collections.size > 0 -%}{%- assign source = product.collections.first -%}{%- endif -%}
<section class="rv-container" style="padding:88px 32px 40px;">
  <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:32px;gap:16px;flex-wrap:wrap;">
    <div>
      <div style="font:600 12px/1 var(--rv-sans);letter-spacing:.26em;text-transform:uppercase;color:var(--rv-clay);margin-bottom:12px;">{{ section.settings.eyebrow }}</div>
      <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(26px,3vw,40px);color:var(--rv-char);margin:0;">{{ section.settings.heading }}</h2>
    </div>
    {%- if source != blank -%}<a href="{{ source.url }}" style="font:500 12px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;color:var(--rv-soft);border-bottom:1px solid var(--rv-soft);padding-bottom:4px;text-decoration:none;">Shop all {{ source.title | downcase }} →</a>{%- endif -%}
  </div>
  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">
    {%- assign shown = 0 -%}
    {%- for p in source.products -%}
      {%- if p.id != product.id and shown < 4 -%}
        {%- assign shown = shown | plus: 1 -%}
        <div>
          <a href="{{ p.url }}" style="display:block;border-radius:3px;overflow:hidden;background:var(--rv-bone-2);margin-bottom:14px;position:relative;text-decoration:none;">
            {%- if p.featured_image != blank -%}{{ p.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', style: 'width:100%;aspect-ratio:4/5;object-fit:cover;display:block;', alt: p.title }}{%- else -%}<div class="rv-placeholder-img" style="aspect-ratio:4/5;">{{ 'product-1' | placeholder_svg_tag }}</div>{%- endif -%}
            {%- if p.available -%}<span style="position:absolute;left:12px;right:12px;bottom:12px;display:block;text-align:center;background:var(--rv-paper);color:var(--rv-char);border:1px solid var(--rv-char);font:600 10px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;padding:11px;border-radius:2px;" data-quickview data-handle="{{ p.handle }}">Quick add</span>{%- endif -%}
          </a>
          <a href="{{ p.url }}" style="font:500 14px/1.3 var(--rv-sans);color:var(--rv-char);text-decoration:none;">{{ p.title }}</a>
          {% render 'rv-material', product: p %}
          <div style="font:600 13px/1 var(--rv-sans);color:var(--rv-char);margin-top:4px;">{{ p.price | money }}</div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{%- endif -%}
{% schema %}{"name":"Style It With","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Complete the look"},
{"type":"text","id":"heading","label":"Heading","default":"Style it with"},
{"type":"collection","id":"collection","label":"Source collection","info":"Pick the Lounge collection. If empty, the product's own first collection is used."}
],"presets":[{"name":"Style It With"}]}{% endschema %}
