
<section style="background:var(--rv-deep);padding:80px 0;">
  <div class="rv-container">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;">
      <div>
        <p class="rv-eyebrow" style="color:var(--rv-butter);">{{ section.settings.eyebrow }}</p>
        <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(30px,3.4vw,50px);line-height:1.04;color:var(--rv-bone);margin:0 0 20px;">{{ section.settings.heading }}</h2>
        <p style="font:400 16px/1.7 var(--rv-sans);color:var(--rv-deep-soft);margin:0 0 28px;">{{ section.settings.body }}</p>
        {%- if section.settings.quote != blank -%}
          <blockquote style="border-left:2px solid var(--rv-butter);padding-left:20px;margin:0 0 28px;">
            <p style="font-family:var(--rv-serif);font-style:italic;font-size:22px;line-height:1.3;color:var(--rv-bone);margin:0 0 8px;">"{{ section.settings.quote }}"</p>
            {%- if section.settings.quote_attr != blank -%}
              <cite style="font:500 11px/1 var(--rv-sans);letter-spacing:.14em;text-transform:uppercase;color:var(--rv-butter);font-style:normal;">{{ section.settings.quote_attr }}</cite>
            {%- endif -%}
          </blockquote>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url }}" class="rv-btn rv-btn--primary">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>
      <div>
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', style: 'width:100%;height:520px;object-fit:cover;border-radius:4px;display:block;', alt: section.settings.image.alt }}
        {%- else -%}
          <div class="rv-placeholder-img" style="height:520px;border-radius:4px;">{{ 'image' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
<style>
@media(max-width:768px){
  .rv-editorial-callout-inner{grid-template-columns:1fr!important;}
}
</style>
{% schema %}{"name":"Editorial Callout","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"The Rare Velvet Edit"},
{"type":"text","id":"heading","label":"Heading","default":"Curated by experts. Designed for your ritual."},
{"type":"textarea","id":"body","label":"Body copy","default":"We test every product we carry — because your skin, your vanity, and your time deserve better than guesswork. Each piece in our edit is chosen for how it feels, performs and lasts."},
{"type":"text","id":"quote","label":"Pull quote (optional)"},
{"type":"text","id":"quote_attr","label":"Quote attribution (optional)"},
{"type":"image_picker","id":"image","label":"Image"},
{"type":"text","id":"cta_label","label":"CTA button label","default":"Read our story"},
{"type":"url","id":"cta_url","label":"CTA link"}
],"presets":[{"name":"Editorial Callout"}]}{% endschema %}