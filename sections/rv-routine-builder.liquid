
<section class="rv-section--bone-2" style="padding:70px 0;">
  <div class="rv-container">
    <div style="text-align:center;margin-bottom:44px;">
      <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="rv-heading">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p style="font:400 15px/1.6 var(--rv-sans);color:var(--rv-soft);max-width:500px;margin:14px auto 0;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="rv-grid-3" style="margin-bottom:40px;">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}>
          <div style="display:flex;align-items:center;gap:14px;margin-bottom:18px;">
            <span style="font-family:var(--rv-serif);font-size:42px;color:var(--rv-butter-2);font-weight:600;line-height:1;flex:none;">0{{ forloop.index }}</span>
            <div style="height:1px;flex:1;background:var(--rv-line);"></div>
          </div>
          {%- if block.settings.product != blank -%}
            {%- assign rp = all_products[block.settings.product] -%}
            <a href="{{ rp.url }}" style="display:block;text-decoration:none;">
              <div style="overflow:hidden;border-radius:3px;margin-bottom:16px;">
                {%- if rp.featured_image -%}
                  {{ rp.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', style: 'width:100%;aspect-ratio:1/1;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.2,.7,.2,1);', alt: rp.title }}
                {%- else -%}
                  <div class="rv-placeholder-img" style="aspect-ratio:1/1;">{{ 'product-1' | placeholder_svg_tag }}</div>
                {%- endif -%}
              </div>
              <div style="font:600 11px/1 var(--rv-sans);letter-spacing:.18em;text-transform:uppercase;color:var(--rv-grey-2);margin-bottom:6px;">{{ block.settings.step_name }}</div>
              <div style="font-family:var(--rv-serif);font-size:20px;color:var(--rv-char);font-weight:500;margin-bottom:4px;">{{ rp.title }}</div>
              <div style="font:400 13px/1 var(--rv-sans);color:var(--rv-soft);margin-bottom:10px;">{{ rp.price | money }}</div>
              <div style="font:400 13px/1.5 var(--rv-sans);color:var(--rv-soft);">{{ block.settings.step_desc }}</div>
            </a>
          {%- elsif block.settings.image != blank -%}
            <div style="overflow:hidden;border-radius:3px;margin-bottom:16px;">
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', style: 'width:100%;aspect-ratio:1/1;object-fit:cover;display:block;', alt: block.settings.step_name }}
            </div>
            <div style="font:600 11px/1 var(--rv-sans);letter-spacing:.18em;text-transform:uppercase;color:var(--rv-grey-2);margin-bottom:6px;">{{ block.settings.step_name }}</div>
            <div style="font-family:var(--rv-serif);font-size:20px;color:var(--rv-char);font-weight:500;margin-bottom:4px;">{{ block.settings.product_name }}</div>
            <div style="font:400 13px/1.5 var(--rv-sans);color:var(--rv-soft);">{{ block.settings.step_desc }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- comment -%} Routine total + variant ids for the discounted add-all {%- endcomment -%}
    {%- assign rb_total = 0 -%}
    {%- assign rb_ids = '' -%}
    {%- for block in section.blocks -%}
      {%- if block.settings.product != blank -%}
        {%- assign rbp = all_products[block.settings.product] -%}
        {%- if rbp.available -%}
          {%- assign rb_total = rb_total | plus: rbp.price -%}
          {%- if rb_ids == '' -%}{%- assign rb_ids = rbp.selected_or_first_available_variant.id -%}{%- else -%}{%- assign rb_ids = rb_ids | append: ',' | append: rbp.selected_or_first_available_variant.id -%}{%- endif -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    {%- assign rb_saving = rb_total | times: section.settings.discount_pct | divided_by: 100 -%}
    {%- assign rb_after = rb_total | minus: rb_saving -%}

    {%- if rb_ids != '' and section.settings.show_add_all -%}
      <div style="text-align:center;">
        <button type="button" class="rv-btn rv-btn--primary" data-add-routine data-ids="{{ rb_ids }}" data-discount="{{ section.settings.discount_code }}" data-auto="{% if section.settings.auto_discount %}1{% else %}0{% endif %}">
          <span class="rv-routine-btn-label">{{ section.settings.add_label }} · {{ rb_after | money }}{% if rb_saving > 0 %} — save {{ rb_saving | money }}{% endif %}</span>
        </button>
        {%- if section.settings.discount_note != blank -%}<p style="font:400 11px/1.5 var(--rv-sans);color:var(--rv-grey-2);font-style:italic;margin:12px 0 0;">{{ section.settings.discount_note }}</p>{%- endif -%}
      </div>
    {%- elsif section.settings.cta_label != blank -%}
      <div style="text-align:center;">
        <a href="{{ section.settings.cta_url }}" class="rv-btn rv-btn--primary">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>
<script>
(function(){
  var btn = document.querySelector('[data-add-routine]'); if(!btn) return;
  var label = btn.querySelector('.rv-routine-btn-label'); var orig = label ? label.textContent : '';
  btn.addEventListener('click', function(){
    var ids = (btn.getAttribute('data-ids')||'').split(',').filter(Boolean); if(!ids.length) return;
    var code = btn.getAttribute('data-discount');
    var auto = btn.getAttribute('data-auto')==='1';
    if(label) label.textContent='Adding\u2026'; btn.disabled=true;
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:ids.map(function(id){return {id:id,quantity:1};})})})
      .then(function(r){ if(r.ok){ if(label) label.textContent='\u2713 Added';
        setTimeout(function(){ window.location.href = (code && !auto) ? ('/discount/'+code+'?redirect=/cart') : '/cart'; }, 700);
      } else { if(label) label.textContent=orig; btn.disabled=false; } })
      .catch(function(){ if(label) label.textContent=orig; btn.disabled=false; });
  });
})();
</script>
{% schema %}{"name":"Routine Builder","tag":"section","max_blocks":4,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Build your ritual"},
{"type":"text","id":"heading","label":"Heading","default":"The Morning Glow Routine"},
{"type":"text","id":"subheading","label":"Subheading","default":"Three steps. Five minutes. All-day glow."},
{"type":"text","id":"cta_label","label":"Fallback CTA label (when no products set)","default":"Shop the full routine"},
{"type":"url","id":"cta_url","label":"CTA link"},
{"type":"header","content":"Add-all bundle discount"},
{"type":"checkbox","id":"show_add_all","label":"Show 'Add all' button with discount","default":true},
{"type":"text","id":"add_label","label":"Add-all button label","default":"Add all 3"},
{"type":"range","id":"discount_pct","label":"Routine discount %","min":0,"max":40,"step":5,"default":15},
{"type":"text","id":"discount_code","label":"Discount code to apply","info":"Create as a CODE discount in Admin → Discounts (15% off the routine products). Applies only when the routine is added here.","default":"GLOW15"},
{"type":"checkbox","id":"auto_discount","label":"Use an automatic discount instead of a code (recommended)","info":"ON: just adds the items and lets a scoped AUTOMATIC discount in Admin → Discounts apply (no code in the URL — safer, combinable, cannot be gamed). OFF: applies the code below via the cart URL.","default":false},
{"type":"text","id":"discount_note","label":"Discount note","default":"15% off the routine is applied automatically when you add all three."}
],"blocks":[{"type":"step","name":"Routine step","settings":[
{"type":"product","id":"product","label":"Product (auto-pulls image + price)"},
{"type":"image_picker","id":"image","label":"Custom image (if no product)"},
{"type":"text","id":"step_name","label":"Step name","default":"Step 1 · Cleanse"},
{"type":"text","id":"product_name","label":"Product name (if no product above)","default":"Gentle Gel Cleanser"},
{"type":"textarea","id":"step_desc","label":"Step description","default":"Remove makeup and impurities without stripping the skin barrier."}
]}],"presets":[{"name":"Routine Builder","blocks":[
{"type":"step","settings":{"step_name":"Step 1 · Cleanse","step_desc":"Remove makeup and impurities without stripping the skin barrier."}},
{"type":"step","settings":{"step_name":"Step 2 · Treat","step_desc":"Apply serum to damp skin for maximum absorption and glow."}},
{"type":"step","settings":{"step_name":"Step 3 · Protect","step_desc":"Seal with moisturiser, then SPF to protect all-day radiance."}}
]}]}{% endschema %}