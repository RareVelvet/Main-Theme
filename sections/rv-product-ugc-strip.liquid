
<section style="padding:40px 0 48px;background:var(--rv-bone);">
  <div class="rv-container">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:16px;">
      <div>
        <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="rv-heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.tag_cta != blank -%}
        <span style="font:500 11px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;color:var(--rv-soft);border-bottom:1px solid var(--rv-line);">{{ section.settings.tag_cta }}</span>
      {%- endif -%}
    </div>
    <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:10px;" class="rv-ugc-photo-grid">
      {%- for block in section.blocks -%}
        <div style="border-radius:3px;overflow:hidden;aspect-ratio:1/1;" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;display:block;', alt: block.settings.image.alt }}
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--rv-bone-2);display:flex;align-items:center;justify-content:center;">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
@media(max-width:768px){
  .rv-ugc-photo-grid{
    display:flex !important;overflow-x:auto;gap:8px;
    scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;
  }
  .rv-ugc-photo-grid::-webkit-scrollbar{display:none}
  .rv-ugc-photo-grid > div{flex:none;width:120px;scroll-snap-align:start;}
}
</style>
{% schema %}{"name":"UGC Photo Strip","tag":"section","max_blocks":8,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"@rarevelvet"},
{"type":"text","id":"heading","label":"Heading","default":"Worn & loved by our community"},
{"type":"text","id":"tag_cta","label":"Tag CTA label","default":""}
],"blocks":[{"type":"photo","name":"Photo","settings":[
{"type":"image_picker","id":"image","label":"Customer photo"}
]}],"presets":[{"name":"UGC Photo Strip"}]}{% endschema %}