
<section class="rv-pdp-section">
  <div class="rv-pdp-look">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;', alt: section.settings.image.alt }}
    {%- else -%}
      <div style="position:absolute;inset:0;background:var(--rv-deep);"></div>
    {%- endif -%}
    <div class="rv-pdp-look__overlay"></div>
    <div class="rv-pdp-look__content">
      <p class="rv-eyebrow" style="color:var(--rv-butter);">{{ section.settings.eyebrow }}</p>
      <h2 class="rv-heading rv-heading--light">{{ section.settings.heading }}</h2>
      <div class="rv-pdp-look__items">
        {%- for block in section.blocks -%}
          <div class="rv-pdp-look__item" {{ block.shopify_attributes }}>
            <span class="rv-pdp-look__item-name">
              {%- if block.settings.product != blank -%}{{ all_products[block.settings.product].title }}{%- else -%}{{ block.settings.item_name }}{%- endif -%}
            </span>
            <div class="rv-pdp-look__item-right">
              <span class="rv-pdp-look__item-price">
                {%- if block.settings.product != blank -%}{{ all_products[block.settings.product].price | money }}{%- else -%}{{ block.settings.item_price }}{%- endif -%}
              </span>
              <a href="{%- if block.settings.product != blank -%}{{ all_products[block.settings.product].url }}{%- else -%}{{ block.settings.link }}{%- endif -%}" class="rv-pdp-look__item-add">Add</a>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Shop the Look","tag":"section","max_blocks":4,"settings":[
{"type":"image_picker","id":"image","label":"Editorial image"},
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Shop the look"},
{"type":"text","id":"heading","label":"Heading","default":"Build your everyday stack"}
],"blocks":[{"type":"look_item","name":"Look item","settings":[
{"type":"product","id":"product","label":"Shopify product (auto name & price)"},
{"type":"text","id":"item_name","label":"Name (if no product)","default":"Item"},
{"type":"text","id":"item_price","label":"Price (if no product)","default":"$0"},
{"type":"url","id":"link","label":"Link (if no product)"}
]}],"presets":[{"name":"Shop the Look","blocks":[{"type":"look_item"},{"type":"look_item"},{"type":"look_item"}]}]}{% endschema %}