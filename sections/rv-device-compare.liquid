{%- comment -%} RV-TYPE-GUARD: renders only for matching product types {%- endcomment -%}
{%- assign rvt = product.type | downcase -%}
{%- assign rv_render = false -%}
{%- if rvt contains 'device' or rvt contains 'tool' -%}{%- assign rv_render = true -%}{%- endif -%}
{%- if rv_render -%}

{%- comment -%} Device comparison table {%- endcomment -%}
<section class="rv-container" style="max-width:1040px;padding:96px 32px 72px;">
  <div style="text-align:center;margin-bottom:44px;">
    <div style="font:600 12px/1 var(--rv-sans);letter-spacing:.26em;text-transform:uppercase;color:var(--rv-clay);margin-bottom:14px;">{{ section.settings.eyebrow }}</div>
    <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(30px,3.6vw,46px);line-height:1.04;margin:0;">{{ section.settings.heading }}</h2>
  </div>
  <div style="border:1px solid var(--rv-line);border-radius:4px;overflow:hidden;">
    <div style="display:grid;grid-template-columns:1.6fr 1fr 1fr;background:var(--rv-char);color:var(--rv-bone);">
      <div style="padding:18px 22px;"></div>
      <div style="padding:18px 22px;font:700 12px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;text-align:center;background:var(--rv-clay);">{{ section.settings.us_label }}</div>
      <div style="padding:18px 22px;font:600 12px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;text-align:center;color:var(--rv-deep-soft);">{{ section.settings.them_label }}</div>
    </div>
    {%- for block in section.blocks -%}
      <div style="display:grid;grid-template-columns:1.6fr 1fr 1fr;border-bottom:1px solid var(--rv-line);background:{% cycle 'var(--rv-paper)', 'var(--rv-bone-2)' %};" {{ block.shopify_attributes }}>
        <div style="padding:15px 22px;font:500 13px/1.4 var(--rv-sans);color:var(--rv-char);">{{ block.settings.feature }}</div>
        <div style="padding:15px 22px;text-align:center;color:var(--rv-clay);font-size:16px;">{{ block.settings.us }}</div>
        <div style="padding:15px 22px;text-align:center;color:var(--rv-grey-2);font-size:16px;">{{ block.settings.them }}</div>
      </div>
    {%- endfor -%}
  </div>
</section>

{%- endif -%}
{% schema %}{"name":"Device Comparison","tag":"section","max_blocks":8,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Why Rare Velvet"},
{"type":"text","id":"heading","label":"Heading","default":"How we compare"},
{"type":"text","id":"us_label","label":"Our column","default":"Velvet Glow Pro"},
{"type":"text","id":"them_label","label":"Their column","default":"Others"}
],"blocks":[{"type":"row","name":"Row","settings":[
{"type":"text","id":"feature","label":"Feature","default":"5 technologies in one wand"},
{"type":"text","id":"us","label":"Ours","default":"✓"},
{"type":"text","id":"them","label":"Theirs","default":"✕"}
]}],"presets":[{"name":"Device Comparison","blocks":[
{"type":"row","settings":{"feature":"5 technologies in one wand","us":"✓","them":"✕"}},
{"type":"row","settings":{"feature":"FDA-cleared","us":"✓","them":"Sometimes"}},
{"type":"row","settings":{"feature":"Therapeutic warmth","us":"✓","them":"✕"}},
{"type":"row","settings":{"feature":"60-night money-back trial","us":"✓","them":"14 days"}},
{"type":"row","settings":{"feature":"HSA/FSA eligible","us":"✓","them":"Rarely"}}
]}]}{% endschema %}
