{%- comment -%} RV-TYPE-GUARD: renders only for matching product types {%- endcomment -%}
{%- assign rvt = product.type | downcase -%}
{%- assign rvtags = product.tags | join: ',' | downcase -%}
{%- assign rv_render = false -%}
{%- if rvt contains 'ring' or rvtags contains 'ring' -%}{%- assign rv_render = true -%}{%- endif -%}
{%- if rv_render -%}

{%- comment -%} Renders only when included; product.liquid gates it on 'ring' in the description {%- endcomment -%}
<section class="rv-pdp-section" style="border-top:1px solid var(--rv-line);padding-top:48px;margin-bottom:48px;">
  <div class="rv-container" style="max-width:760px;">
    <p class="rv-eyebrow" style="text-align:center;">{{ section.settings.eyebrow }}</p>
    <h2 class="rv-heading" style="text-align:center;margin-bottom:28px;">{{ section.settings.heading }}</h2>

    <div class="rv-ringguide-methods">
      <div>
        <div class="rv-ringguide-method-h">{{ section.settings.method1_title }}</div>
        <p class="rv-ringguide-method-p">{{ section.settings.method1_text }}</p>
      </div>
      <div>
        <div class="rv-ringguide-method-h">{{ section.settings.method2_title }}</div>
        <p class="rv-ringguide-method-p">{{ section.settings.method2_text }}</p>
      </div>
    </div>

    <table class="rv-ringguide-table">
      <thead>
        <tr><th>US</th><th>UK</th><th>EU</th><th>Diameter</th><th>Circumference</th></tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          <tr {{ block.shopify_attributes }}>
            <td class="rv-ringguide-us">{{ block.settings.us }}</td>
            <td>{{ block.settings.uk }}</td>
            <td>{{ block.settings.eu }}</td>
            <td>{{ block.settings.diameter }}</td>
            <td>{{ block.settings.circumference }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
    {%- if section.settings.tip != blank -%}
      <p class="rv-ringguide-tip">{{ section.settings.tip }}</p>
    {%- endif -%}
  </div>
</section>

<style>
.rv-ringguide-methods{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:24px;}
.rv-ringguide-method-h{font:600 10px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;color:var(--rv-char);margin-bottom:7px;}
.rv-ringguide-method-p{font:400 13px/1.6 var(--rv-sans);color:var(--rv-soft);margin:0;}
.rv-ringguide-table{width:100%;border-collapse:collapse;font:400 13px/1 var(--rv-sans);}
.rv-ringguide-table th{text-align:left;padding:11px 12px;font:600 9px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;color:var(--rv-grey-2);background:var(--rv-bone-2);}
.rv-ringguide-table td{padding:11px 12px;border-bottom:1px solid var(--rv-line);color:var(--rv-soft);}
.rv-ringguide-table tbody tr:nth-child(even){background:rgba(242,230,194,.12);}
.rv-ringguide-us{color:var(--rv-char)!important;font-weight:600;}
.rv-ringguide-tip{font:400 12px/1.5 var(--rv-sans);color:var(--rv-grey-2);font-style:italic;margin:14px 0 0;}
@media(max-width:768px){.rv-ringguide-methods{grid-template-columns:1fr;gap:16px;}}
</style>


{%- endif -%}
{% schema %}{"name":"Ring Size Guide","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Find your fit"},
{"type":"text","id":"heading","label":"Heading","default":"Ring size guide"},
{"type":"text","id":"method1_title","label":"Method 1 title","default":"Measure a ring"},
{"type":"textarea","id":"method1_text","label":"Method 1 text","default":"Take a ring that already fits and measure the inner diameter in mm. Match it to the chart below."},
{"type":"text","id":"method2_title","label":"Method 2 title","default":"Measure your finger"},
{"type":"textarea","id":"method2_text","label":"Method 2 text","default":"Wrap a strip of paper around your finger, mark where it meets, and measure the length (circumference)."},
{"type":"text","id":"tip","label":"Tip","default":"Measure at the end of the day when fingers are warmest, and size up if you're between sizes."}
],"blocks":[{"type":"row","name":"Size row","settings":[
{"type":"text","id":"us","label":"US","default":"6"},
{"type":"text","id":"uk","label":"UK","default":"L½"},
{"type":"text","id":"eu","label":"EU","default":"52"},
{"type":"text","id":"diameter","label":"Diameter","default":"16.5 mm"},
{"type":"text","id":"circumference","label":"Circumference","default":"51.9 mm"}
]}],"presets":[{"name":"Ring Size Guide","blocks":[
{"type":"row","settings":{"us":"5","uk":"J½","eu":"49","diameter":"15.7 mm","circumference":"49.3 mm"}},
{"type":"row","settings":{"us":"6","uk":"L½","eu":"52","diameter":"16.5 mm","circumference":"51.9 mm"}},
{"type":"row","settings":{"us":"7","uk":"N½","eu":"54","diameter":"17.3 mm","circumference":"54.4 mm"}},
{"type":"row","settings":{"us":"8","uk":"P½","eu":"57","diameter":"18.1 mm","circumference":"57.0 mm"}},
{"type":"row","settings":{"us":"9","uk":"R½","eu":"59","diameter":"19.0 mm","circumference":"59.5 mm"}},
{"type":"row","settings":{"us":"10","uk":"T½","eu":"62","diameter":"19.8 mm","circumference":"62.1 mm"}}
]}]}{% endschema %}