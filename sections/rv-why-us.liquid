
<section class="rv-section--deep" style="margin-top:0;padding:70px 0;">
  <div class="rv-container">
    <div style="text-align:center;margin-bottom:48px;">
      <p class="rv-eyebrow" style="color:var(--rv-butter);">{{ section.settings.eyebrow }}</p>
      <h2 class="rv-heading rv-heading--light">{{ section.settings.heading }}</h2>
    </div>
    <div class="rv-grid-4">
      {%- for block in section.blocks -%}
        <div style="text-align:center;padding:0 8px;" {{ block.shopify_attributes }}>
          <div style="width:56px;height:56px;margin:0 auto 18px;border-radius:999px;background:var(--rv-butter);display:flex;align-items:center;justify-content:center;">
            {%- if block.settings.icon_image != blank -%}
              {{ block.settings.icon_image | image_url: width: 40 | image_tag: loading: 'lazy', style: 'width:28px;height:28px;object-fit:contain;' }}
            {%- else -%}
              <span style="width:15px;height:15px;background:var(--rv-deep);border-radius:{{ block.settings.icon_shape }};display:block;"></span>
            {%- endif -%}
          </div>
          <div style="font-family:var(--rv-serif);font-size:21px;color:var(--rv-bone);font-weight:500;margin-bottom:8px;">{{ block.settings.title }}</div>
          <p style="font:400 13px/1.55 var(--rv-sans);color:var(--rv-deep-soft);margin:0;">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{"name":"Why Us","tag":"section","max_blocks":4,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"The Rare Velvet difference"},
{"type":"text","id":"heading","label":"Heading","default":"Considered in every detail"}
],"blocks":[{"type":"pillar","name":"Trust pillar","settings":[
{"type":"image_picker","id":"icon_image","label":"Icon image (optional)"},
{"type":"select","id":"icon_shape","label":"Icon shape (if no image)","options":[{"value":"999px","label":"Circle"},{"value":"3px","label":"Square"},{"value":"50% 50% 50% 0","label":"Teardrop"}],"default":"999px"},
{"type":"text","id":"title","label":"Title","default":"Editor-Curated"},
{"type":"textarea","id":"description","label":"Description","default":"Every piece is hand-selected and checked for material, wear and finish."}
]}],"presets":[{"name":"Why Us","blocks":[
{"type":"pillar","settings":{"title":"Editor-Curated","description":"Every piece is hand-selected and checked for material, wear and finish before it earns a place in the edit.","icon_shape":"999px"}},
{"type":"pillar","settings":{"title":"Ships in 24 Hours","description":"Orders leave our studio within a day — tracked, carbon-neutral delivery, with a tracking link by email.","icon_shape":"3px"}},
{"type":"pillar","settings":{"title":"Arrives Gift-Ready","description":"Wrapped in our signature velvet pouch and hand-finished box — ready to gift, beautiful to keep.","icon_shape":"50% 50% 50% 0"}},
{"type":"pillar","settings":{"title":"Shop with Confidence","description":"Encrypted checkout, easy 30-day returns, and a lifetime warranty on every jewelry box.","icon_shape":"999px"}}
]}]}{% endschema %}