
<section class="rv-section">
  <div class="rv-container">
    <div class="rv-section-head">
      <div>
        <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="rv-heading" style="max-width:600px;">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.blog != blank -%}
        <a href="{{ blogs[section.settings.blog].url }}" class="rv-view-all">{{ section.settings.view_all_label }}</a>
      {%- endif -%}
    </div>

    {%- assign blog_obj = blogs[section.settings.blog] -%}
    {%- assign featured = blog_obj.articles.first -%}

    <div class="rv-journal-grid">
      <!-- Featured article -->
      {%- if featured != blank -%}
        <a href="{{ featured.url }}" class="rv-journal-featured">
          <div class="rv-journal-featured__img-wrap">
            {%- if featured.image != blank -%}
              {{ featured.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'rv-journal-featured__img', alt: featured.title }}
            {%- else -%}
              <div class="rv-journal-featured__img rv-placeholder-img">{{ 'image' | placeholder_svg_tag }}</div>
            {%- endif -%}
            <span class="rv-journal-pick">Editor's Pick</span>
          </div>
          <div class="rv-journal-featured__cat">{{ featured.tags.first | default: 'The Edit' }} · {{ featured.content | strip_html | truncatewords: 60 | size | divided_by: 200 | plus: 1 }} min read</div>
          <h3 class="rv-journal-featured__title">{{ featured.title }}</h3>
          <p class="rv-journal-featured__excerpt">{{ featured.excerpt_or_content | strip_html | truncatewords: 28 }}</p>
          <span class="rv-journal-featured__cta">Read the story →</span>
        </a>
      {%- else -%}
        <a class="rv-journal-featured">
          <div class="rv-journal-featured__img-wrap">
            <div class="rv-journal-featured__img rv-placeholder-img">{{ 'image' | placeholder_svg_tag }}</div>
            <span class="rv-journal-pick">Editor's Pick</span>
          </div>
          <div class="rv-journal-featured__cat">The Edit · 6 min read</div>
          <h3 class="rv-journal-featured__title">{{ section.settings.placeholder_title }}</h3>
          <p class="rv-journal-featured__excerpt">{{ section.settings.placeholder_excerpt }}</p>
          <span class="rv-journal-featured__cta">Read the story →</span>
        </a>
      {%- endif -%}

      <!-- Side list -->
      <div class="rv-journal-list">
        {%- if blog_obj.articles.size > 1 -%}
          {%- for article in blog_obj.articles offset: 1 limit: 3 -%}
            <a href="{{ article.url }}" class="rv-journal-item">
              <div class="rv-journal-item__img-wrap">
                {%- if article.image != blank -%}
                  {{ article.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'rv-journal-item__img', alt: article.title }}
                {%- else -%}
                  <div class="rv-journal-item__img rv-placeholder-img">{{ 'image' | placeholder_svg_tag }}</div>
                {%- endif -%}
              </div>
              <div>
                <div class="rv-journal-item__cat">{{ article.tags.first | default: 'Journal' }}</div>
                <h4 class="rv-journal-item__title">{{ article.title }}</h4>
              </div>
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            <div class="rv-journal-item" {{ block.shopify_attributes }}>
              <div class="rv-journal-item__img-wrap">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'rv-journal-item__img', alt: block.settings.title }}
                {%- else -%}
                  <div class="rv-journal-item__img rv-placeholder-img">{{ 'image' | placeholder_svg_tag }}</div>
                {%- endif -%}
              </div>
              <div>
                <div class="rv-journal-item__cat">{{ block.settings.category }} · {{ block.settings.read_time }}</div>
                <h4 class="rv-journal-item__title">{{ block.settings.title }}</h4>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
.rv-journal-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:36px;align-items:start;}
.rv-journal-featured{display:block;cursor:pointer;}
.rv-journal-featured__img-wrap{position:relative;border-radius:4px;overflow:hidden;margin-bottom:22px;}
.rv-journal-featured__img{width:100%;aspect-ratio:16/10;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.2,.7,.2,1);}
.rv-journal-featured:hover .rv-journal-featured__img{transform:scale(1.03);}
.rv-journal-pick{position:absolute;top:16px;left:16px;background:var(--rv-paper);color:var(--rv-char);font:600 10px/1 var(--rv-sans);letter-spacing:.14em;text-transform:uppercase;padding:7px 12px;border-radius:999px;}
.rv-journal-featured__cat{font:600 11px/1 var(--rv-sans);letter-spacing:.2em;text-transform:uppercase;color:var(--rv-clay);margin-bottom:12px;}
.rv-journal-featured__title{font-family:var(--rv-serif);font-weight:500;font-size:clamp(26px,2.6vw,38px);line-height:1.08;color:var(--rv-char);margin:0 0 14px;}
.rv-journal-featured__excerpt{font:400 15px/1.65 var(--rv-sans);color:var(--rv-soft);margin:0 0 16px;max-width:540px;}
.rv-journal-featured__cta{font:500 12px/1 var(--rv-sans);letter-spacing:.12em;text-transform:uppercase;color:var(--rv-char);border-bottom:1px solid var(--rv-butter-2);padding-bottom:3px;}
.rv-journal-list{display:flex;flex-direction:column;border-bottom:1px solid var(--rv-line);}
.rv-journal-item{display:flex;gap:18px;padding:20px 0;border-top:1px solid var(--rv-line);cursor:pointer;align-items:center;}
.rv-journal-item__img-wrap{width:120px;height:120px;flex:none;border-radius:3px;overflow:hidden;}
.rv-journal-item__img{width:100%;height:100%;object-fit:cover;display:block;}
.rv-journal-item__cat{font:600 10px/1 var(--rv-sans);letter-spacing:.18em;text-transform:uppercase;color:var(--rv-clay);margin-bottom:9px;}
.rv-journal-item__title{font-family:var(--rv-serif);font-weight:500;font-size:21px;line-height:1.15;color:var(--rv-char);margin:0;}
@media(max-width:768px){
  .rv-journal-grid{grid-template-columns:1fr;gap:24px;}
  .rv-journal-item__img-wrap{width:88px;height:88px;}
  .rv-journal-item__title{font-size:18px;}
}
</style>

{% schema %}{"name":"Journal","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"The Rare Velvet Journal"},
{"type":"text","id":"heading","label":"Heading","default":"Notes on beauty, ritual & everyday luxury"},
{"type":"blog","id":"blog","label":"Blog source","info":"Pick a blog to pull live articles. If empty or only 1 article, the manual items below are used."},
{"type":"text","id":"view_all_label","label":"View all label","default":"All articles →"},
{"type":"header","content":"Fallback featured (when no blog selected)"},
{"type":"text","id":"placeholder_title","label":"Placeholder title","default":"The art of the everyday vanity: styling your space like an editor"},
{"type":"textarea","id":"placeholder_excerpt","label":"Placeholder excerpt","default":"From the perfect tray to the pieces worth displaying — our beauty editors share how to turn a morning routine into a ritual worth slowing down for."}
],"blocks":[{"type":"post","name":"Manual post","settings":[
{"type":"image_picker","id":"image","label":"Image"},
{"type":"text","id":"category","label":"Category","default":"Ritual"},
{"type":"text","id":"read_time","label":"Read time","default":"4 min"},
{"type":"text","id":"title","label":"Title","default":"A five-minute morning glow routine"}
]}],"max_blocks":3,"presets":[{"name":"Journal","blocks":[
{"type":"post","settings":{"category":"Ritual","read_time":"4 min","title":"A five-minute morning glow routine, edited down to essentials"}},
{"type":"post","settings":{"category":"Guides","read_time":"5 min","title":"How to pack your jewelry for travel (without the tangles)"}},
{"type":"post","settings":{"category":"Gifting","read_time":"3 min","title":"The Rare Velvet gift guide: under-$50 pieces they'll love"}}
]}]}{% endschema %}