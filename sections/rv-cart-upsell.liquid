
<div class="rv-cart-upsell" id="rv-cart-upsell-{{ section.id }}" style="margin-top:32px;padding-top:32px;border-top:1px solid var(--rv-line);">
  <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:16px;">
    <div>
      <p class="rv-eyebrow" style="margin-bottom:6px;">{{ section.settings.eyebrow }}</p>
      <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(20px,2.4vw,26px);color:var(--rv-char);margin:0;">{{ section.settings.heading }}</h2>
    </div>
  </div>

  {%- comment -%}
    Plugin detection — if Rebuy or LimeSpot are installed they inject their
    own widgets via data attributes below; native recs are the fallback.
  {%- endcomment -%}

  {%- if section.settings.rebuy_widget_id != blank -%}
    <!-- Rebuy Smart Cart upsell widget (requires Rebuy app) -->
    <div data-rebuy-id="{{ section.settings.rebuy_widget_id }}"></div>
  {%- else -%}
    <!-- Native Shopify Product Recommendations (no app needed) -->
    <div class="rv-upsell-grid" id="rv-upsell-items-{{ section.id }}">
      <!-- Populated by JS below -->
      <div class="rv-upsell-placeholder"></div>
      <div class="rv-upsell-placeholder"></div>
      <div class="rv-upsell-placeholder"></div>
    </div>

    <script>
    (function(){
      var rootId = 'rv-cart-upsell-{{ section.id }}';
      var itemsId = 'rv-upsell-items-{{ section.id }}';
      // Use the last item in cart as the seed product for recommendations
      var cartItems = {{ cart.items | json }};
      if (!cartItems || !cartItems.length) return;

      // Pick the highest-priced item as the seed (most relevant upsell anchor)
      var seed = cartItems.sort(function(a,b){ return b.price - a.price; })[0];
      var limit = {{ section.settings.count }};
      var cartProductIds = cartItems.map(function(i){ return i.product_id; });

      fetch('/recommendations/products.json?product_id=' + seed.product_id + '&limit=' + (limit + cartProductIds.length) + '&intent=related')
        .then(function(r){ return r.json(); })
        .then(function(data){
          // Filter out products already in cart
          var recs = (data.products || [])
            .filter(function(p){ return cartProductIds.indexOf(p.id) === -1; })
            .slice(0, limit);

          if (!recs.length) {
            document.getElementById(rootId).style.display = 'none';
            return;
          }

          var html = recs.map(function(p){
            var img = p.featured_image
              ? '<img src="' + p.featured_image.replace(/.jpg|.png|.webp/, '_200x250_crop_center$&') + '" alt="' + p.title + '" style="width:100%;height:100%;object-fit:cover;display:block;">'
              : '<div style="width:100%;height:100%;background:var(--rv-bone-2);"></div>';
            var price = (p.price_min / 100).toLocaleString('en-US',{style:'currency',currency:'{{ shop.currency }}'});
            var varId = p.variants[0].id;
            return '<div class="rv-upsell-card">'
              + '<div class="rv-upsell-card__img">' + img + '</div>'
              + '<div class="rv-upsell-card__body">'
              + '<div class="rv-upsell-card__name">' + p.title + '</div>'
              + '<div class="rv-upsell-card__price">' + price + '</div>'
              + '<button class="rv-upsell-card__add rv-btn rv-btn--primary" data-variant="' + varId + '" onclick="rvUpsellAdd(this,' + varId + ')">Add to bag +</button>'
              + '</div>'
              + '</div>';
          }).join('');

          document.getElementById(itemsId).innerHTML = html;
        })
        .catch(function(){ document.getElementById(rootId).style.display = 'none'; });

      // Quick-add handler
      window.rvUpsellAdd = function(btn, variantId) {
        btn.textContent = 'Adding…';
        btn.disabled = true;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        }).then(function(r){
          if (r.ok) {
            btn.textContent = '✓ Added!';
            btn.style.background = 'var(--rv-deep)';
            setTimeout(function(){ window.location.reload(); }, 700);
          } else {
            btn.textContent = 'Add to bag +';
            btn.disabled = false;
          }
        });
      };
    })();
    </script>
  {%- endif -%}
</div>

<style>
.rv-upsell-grid{display:grid;grid-template-columns:repeat({{ section.settings.count }},1fr);gap:12px;}
.rv-upsell-placeholder{aspect-ratio:3/4;background:var(--rv-bone-2);border-radius:3px;animation:rv-pulse 1.4s ease-in-out infinite;}
@keyframes rv-pulse{0%,100%{opacity:.6}50%{opacity:1}}
.rv-upsell-card{background:var(--rv-paper);border:1px solid var(--rv-line);border-radius:3px;overflow:hidden;display:flex;flex-direction:column;}
.rv-upsell-card__img{aspect-ratio:3/4;overflow:hidden;background:var(--rv-bone-2);}
.rv-upsell-card__body{padding:12px;display:flex;flex-direction:column;gap:6px;flex:1;}
.rv-upsell-card__name{font:500 13px/1.3 var(--rv-sans);color:var(--rv-char);}
.rv-upsell-card__price{font:400 12px/1 var(--rv-sans);color:var(--rv-grey-2);}
.rv-upsell-card__add{font-size:11px!important;padding:10px 12px!important;margin-top:auto;}
@media(max-width:768px){
  .rv-upsell-grid{
    display:flex!important;overflow-x:auto;gap:10px;
    scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;
    padding-bottom:4px;
  }
  .rv-upsell-grid::-webkit-scrollbar{display:none}
  .rv-upsell-card{flex:none;width:48vw;scroll-snap-align:start;}
}
@media(max-width:480px){.rv-upsell-card{width:64vw;}}
</style>

{% schema %}{"name":"Cart Upsell","tag":"div","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"You might also like"},
{"type":"text","id":"heading","label":"Heading","default":"Complete your order"},
{"type":"range","id":"count","label":"Products to show","min":2,"max":4,"step":1,"default":3},
{"type":"header","content":"Plugin integration"},
{"type":"text","id":"rebuy_widget_id","label":"Rebuy widget ID (leave blank to use native Shopify recommendations)","info":"If you have the Rebuy app installed, paste your Smart Cart widget ID here. Otherwise, Shopify's native product recommendations are used automatically — no app required."}
],"presets":[{"name":"Cart Upsell"}]}{% endschema %}