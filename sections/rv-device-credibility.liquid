{%- comment -%} RV-TYPE-GUARD: renders only for matching product types {%- endcomment -%}
{%- assign rvt = product.type | downcase -%}
{%- assign rv_render = false -%}
{%- if rvt contains 'device' or rvt contains 'tool' -%}{%- assign rv_render = true -%}{%- endif -%}
{%- if rv_render -%}

{%- comment -%} Device credibility strip — 4 stats on deep band {%- endcomment -%}
<section style="background:var(--rv-deep);">
  <div class="rv-container" style="padding:40px 32px;display:grid;grid-template-columns:repeat(4,1fr);gap:28px;">
    {%- for block in section.blocks -%}
      <div style="text-align:center;" {{ block.shopify_attributes }}>
        <div style="font-family:var(--rv-serif);font-size:38px;color:var(--rv-butter);font-weight:500;line-height:1;margin-bottom:8px;">{{ block.settings.stat }}</div>
        <div style="font:400 13px/1.5 var(--rv-sans);color:var(--rv-deep-soft);max-width:200px;margin:0 auto;">{{ block.settings.label }}</div>
      </div>
    {%- endfor -%}
  </div>
</section>
<style>@media(max-width:640px){section .rv-container[style*="repeat(4"]{grid-template-columns:1fr 1fr!important;}}</style>

{%- endif -%}
{% schema %}{"name":"Device Credibility","tag":"section","max_blocks":4,"blocks":[{"type":"stat","name":"Stat","settings":[
{"type":"text","id":"stat","label":"Stat","default":"Add a stat","info":"Only use claims you can substantiate (certifications, clinical results, real sales/review figures). Regulatory terms like ‘FDA cleared’ must be accurate for your product."},
{"type":"text","id":"label","label":"Label","default":"Add a label"}
]}],"presets":[{"name":"Device Credibility","blocks":[
{"type":"stat","settings":{"stat":"Add a stat","label":"Add a label"}},
{"type":"stat","settings":{"stat":"Add a stat","label":"Add a label"}},
{"type":"stat","settings":{"stat":"Add a stat","label":"Add a label"}},
{"type":"stat","settings":{"stat":"Add a stat","label":"Add a label"}}
]}]}{% endschema %}
