
<section style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:80px 24px;">
  <div>
    <p style="font:600 11px/1 var(--rv-sans);letter-spacing:.26em;text-transform:uppercase;color:var(--rv-grey-2);margin:0 0 16px;">{{ section.settings.eyebrow }}</p>
    <h1 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(36px,6vw,80px);color:var(--rv-char);margin:0 0 16px;">{{ section.settings.heading }}</h1>
    <p style="font:400 16px/1.6 var(--rv-sans);color:var(--rv-soft);max-width:440px;margin:0 auto 32px;">{{ section.settings.subheading }}</p>
    <a href="{{ routes.root_url }}" class="rv-btn rv-btn--primary">{{ section.settings.cta }}</a>
  </div>
</section>
{% schema %}{"name":"404","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"404 — Page not found"},
{"type":"text","id":"heading","label":"Heading","default":"Nothing here"},
{"type":"textarea","id":"subheading","label":"Subheading","default":"The page you're looking for has moved or doesn't exist."},
{"type":"text","id":"cta","label":"CTA label","default":"Back to home"}
],"presets":[{"name":"404"}]}{% endschema %}