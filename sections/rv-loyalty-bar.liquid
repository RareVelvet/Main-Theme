
{%- if section.settings.show -%}
<div style="background:var(--rv-butter);border-top:1px solid var(--rv-butter-2);border-bottom:1px solid var(--rv-butter-2);">
  <div class="rv-container" style="padding:16px 32px;">
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap;text-align:center;">
      <span style="font:600 12px/1 var(--rv-sans);letter-spacing:.14em;text-transform:uppercase;color:var(--rv-char);">{{ section.settings.icon }} {{ section.settings.text }}</span>
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" style="font:500 12px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;color:var(--rv-char);border-bottom:1px solid var(--rv-char);padding-bottom:1px;">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>
  </div>
</div>
{%- endif -%}
{% schema %}{"name":"Loyalty Bar","tag":"section","settings":[
{"type":"checkbox","id":"show","label":"Show bar","default":true},
{"type":"text","id":"icon","label":"Icon or emoji","default":"★"},
{"type":"text","id":"text","label":"Text","default":"Earn points with every purchase — join Rare Velvet Rewards"},
{"type":"text","id":"link_label","label":"Link label","default":"Learn more"},
{"type":"url","id":"link","label":"Link"}
],"presets":[{"name":"Loyalty Bar"}]}{% endschema %}