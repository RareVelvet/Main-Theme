
<section style="padding:0 0 36px;background:var(--rv-bone);">
  <div class="rv-container">
    <p class="rv-eyebrow" style="color:var(--rv-clay);">{{ section.settings.eyebrow }}</p>
    <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:6px;">
      <h2 class="rv-heading" style="margin:0;">{{ section.settings.heading }}</h2>
      {%- if section.settings.offer_enabled -%}
        <span style="font:600 10px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;color:var(--rv-clay);background:var(--rv-butter);border-radius:999px;padding:6px 11px;">Save {{ section.settings.discount_pct }}% added together</span>
      {%- endif -%}
    </div>
    <p style="font:400 13px/1.5 var(--rv-sans);color:var(--rv-grey-2);margin:0 0 20px;">Store it beautifully — tap any pieces to add, your total updates as you go.</p>

    {%- assign van_col = collections[section.settings.collection] -%}
    {%- if van_col == blank or van_col.products_count == 0 -%}
      {%- assign van_col = collections['vanity'] -%}
    {%- endif -%}

    {%- assign shown = 0 -%}
    {%- if van_col != blank -%}
      <div class="rv-vanity-row" data-vanity data-discount-pct="{{ section.settings.discount_pct }}" data-discount-code="{{ section.settings.discount_code }}" data-auto="{% if section.settings.auto_discount %}1{% else %}0{% endif %}">
        {%- for vp in van_col.products -%}
          {%- if shown >= section.settings.count -%}{% break %}{%- endif -%}
          {%- unless vp.id == product.id -%}
            {%- if vp.available -%}
              {%- assign shown = shown | plus: 1 -%}
              <button type="button" class="rv-vanity-item" data-vanity-piece data-variant="{{ vp.selected_or_first_available_variant.id }}" data-price="{{ vp.price }}" aria-pressed="false">
                <div class="rv-vanity-thumb">
                  {%- if vp.featured_image -%}
                    {{ vp.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'rv-vanity-img', alt: vp.title }}
                  {%- else -%}
                    <div class="rv-vanity-img rv-placeholder-img">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {%- endif -%}
                  <span class="rv-vanity-check" aria-hidden="true"></span>
                </div>
                <div class="rv-vanity-label">{{ vp.title | truncate: 24 }}</div>
                <div class="rv-vanity-price">{{ vp.price | money }}</div>
              </button>
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>

      {%- if shown > 0 -%}
        <button type="button" class="rv-btn rv-btn--outline" data-add-vanity style="display:inline-flex;margin-bottom:0;">
          <span class="rv-vanity-btn-label">{{ section.settings.add_label }}</span>
        </button>
        {%- if section.settings.offer_enabled and section.settings.offer_note != blank -%}
          <p style="font:400 11px/1.5 var(--rv-sans);color:var(--rv-grey-2);font-style:italic;margin:10px 0 0;">{{ section.settings.offer_note }}</p>
        {%- endif -%}
      {%- endif -%}
    {%- else -%}
      <p style="font:400 13px/1.5 var(--rv-sans);color:var(--rv-grey-2);">Add storage products to a collection named “Vanity” (or set one in this section) to populate this automatically.</p>
    {%- endif -%}
  </div>
</section>

<style>
.rv-vanity-row{display:flex;gap:12px;overflow-x:auto;padding-bottom:8px;margin-bottom:16px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.rv-vanity-row::-webkit-scrollbar{display:none}
.rv-vanity-item{flex:none;width:150px;scroll-snap-align:start;text-align:left;background:var(--rv-paper);border:1px solid var(--rv-line);border-radius:3px;overflow:hidden;padding:0;cursor:pointer;font:inherit;transition:border-color .2s;}
.rv-vanity-item.is-selected{border-color:var(--rv-char);}
.rv-vanity-thumb{position:relative;width:100%;aspect-ratio:1/1;overflow:hidden;background:var(--rv-bone-2);}
.rv-vanity-img{width:100%;height:100%;object-fit:cover;display:block;}
.rv-vanity-check{position:absolute;top:8px;right:8px;width:22px;height:22px;border-radius:999px;border:1.5px solid #FBF9F4;background:rgba(43,42,39,.35);display:flex;align-items:center;justify-content:center;}
.rv-vanity-item.is-selected .rv-vanity-check{background:var(--rv-char);border-color:var(--rv-char);}
.rv-vanity-item.is-selected .rv-vanity-check::after{content:"";width:9px;height:5px;border-left:1.5px solid #FBF9F4;border-bottom:1.5px solid #FBF9F4;transform:rotate(-45deg) translateY(-1px);}
.rv-vanity-label{font:500 12px/1.3 var(--rv-sans);color:var(--rv-char);padding:10px 10px 2px;}
.rv-vanity-price{font:400 11px/1 var(--rv-sans);color:var(--rv-soft);padding:0 10px 11px;}
</style>

<script>
(function(){
  var row = document.querySelector('[data-vanity]');
  if(!row) return;
  var btn = document.querySelector('[data-add-vanity]');
  var label = btn ? btn.querySelector('.rv-vanity-btn-label') : null;
  var baseLabel = label ? label.textContent : 'Add to bag';
  var pct = parseFloat(row.getAttribute('data-discount-pct')) || 0;
  var code = row.getAttribute('data-discount-code') || '';
  var auto = row.getAttribute('data-auto')==='1';
  var fmt = (window.Shopify && Shopify.formatMoney) ? function(c){ return Shopify.formatMoney(c); } : function(c){ return '$' + (c/100).toFixed(2); };

  function selected(){ return [].slice.call(row.querySelectorAll('[data-vanity-piece].is-selected')); }
  function update(){
    var items = selected();
    if(!items.length){ if(label) label.textContent = baseLabel; if(btn) btn.disabled = true; return; }
    if(btn) btn.disabled = false;
    var total = items.reduce(function(s,el){ return s + (parseInt(el.getAttribute('data-price'),10)||0); }, 0);
    var saving = Math.round(total * pct / 100);
    var after = total - saving;
    if(label) label.textContent = 'Add ' + items.length + ' · ' + fmt(after) + (saving>0 ? ' — save ' + fmt(saving) : '');
  }
  row.querySelectorAll('[data-vanity-piece]').forEach(function(el){
    el.addEventListener('click', function(){
      var on = el.classList.toggle('is-selected');
      el.setAttribute('aria-pressed', on ? 'true':'false');
      update();
    });
  });
  update();

  if(btn){
    btn.addEventListener('click', function(){
      var ids = selected().map(function(el){ return el.getAttribute('data-variant'); }).filter(Boolean);
      if(!ids.length) return;
      var orig = label ? label.textContent : '';
      if(label) label.textContent = 'Adding…'; btn.disabled = true;
      fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:ids.map(function(id){return {id:id,quantity:1};})})})
        .then(function(r){
          if(r.ok){ if(label) label.textContent='✓ Added';
            setTimeout(function(){ window.location.href = (code && !auto) ? ('/discount/'+code+'?redirect=/cart') : '/cart'; }, 700);
          } else { if(label) label.textContent=orig; btn.disabled=false; }
        }).catch(function(){ if(label) label.textContent=orig; btn.disabled=false; });
    });
  }
})();
</script>

{% schema %}{"name":"Complete Your Vanity","tag":"section","settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Store it beautifully"},
{"type":"text","id":"heading","label":"Heading","default":"Complete your vanity"},
{"type":"paragraph","content":"Auto-pulls storage pieces from the collection below (or a collection with the handle 'vanity'). Shoppers tap any number; total + discount update live."},
{"type":"collection","id":"collection","label":"Vanity / storage collection"},
{"type":"range","id":"count","label":"Pieces to show","min":2,"max":10,"step":1,"default":5},
{"type":"header","content":"Buy-together offer"},
{"type":"checkbox","id":"offer_enabled","label":"Offer a discount when added here","default":true},
{"type":"range","id":"discount_pct","label":"Discount %","min":0,"max":30,"step":5,"default":10},
{"type":"text","id":"discount_code","label":"Discount code to apply","info":"Create as a CODE discount in Admin → Discounts (e.g. 10% off the storage collection). Mark NON-combinable.","default":"VANITY10"},
{"type":"checkbox","id":"auto_discount","label":"Use an automatic discount instead of a code (recommended)","info":"ON: just adds the items and lets a scoped AUTOMATIC discount in Admin → Discounts apply (no code in the URL — safer, combinable, cannot be gamed). OFF: applies the code below via the cart URL.","default":false},
{"type":"text","id":"add_label","label":"Add button label","default":"Add to bag"},
{"type":"text","id":"offer_note","label":"Offer note","default":"10% off applied when you add storage pieces with this item."}
],"presets":[{"name":"Complete Your Vanity"}]}{% endschema %}
