
<section class="rv-section">
  <div class="rv-container">
    <div class="rv-grid-4">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" style="display:block;cursor:pointer;text-decoration:none;" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', style: 'width:100%;height:220px;object-fit:cover;border-radius:3px;display:block;', alt: block.settings.title }}
          {%- elsif block.settings.collection != blank -%}
            {%- assign fc = collections[block.settings.collection] -%}
            {%- if fc.image -%}
              {{ fc.image | image_url: width: 500 | image_tag: loading: 'lazy', style: 'width:100%;height:220px;object-fit:cover;border-radius:3px;display:block;', alt: block.settings.title }}
            {%- else -%}
              <div class="rv-placeholder-img" style="height:220px;border-radius:3px;">{{ 'collection-1' | placeholder_svg_tag }}</div>
            {%- endif -%}
          {%- else -%}
            <div class="rv-placeholder-img" style="height:220px;border-radius:3px;">{{ 'image' | placeholder_svg_tag }}</div>
          {%- endif -%}
          <div style="display:flex;align-items:center;justify-content:space-between;margin-top:14px;">
            <span style="font-family:var(--rv-serif);font-size:19px;color:var(--rv-char);font-weight:500;">{{ block.settings.title }}</span>
            <span style="font:400 12px/1 var(--rv-sans);letter-spacing:.14em;text-transform:uppercase;color:var(--rv-soft);">Shop →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}{"name":"Featured Collections","tag":"section","max_blocks":4,"blocks":[{"type":"collection","name":"Collection link","settings":[
{"type":"image_picker","id":"image","label":"Image"},
{"type":"collection","id":"collection","label":"Collection (auto image if none above)"},
{"type":"text","id":"title","label":"Title","default":"Night Routine"},
{"type":"url","id":"link","label":"Link"}
]}],"presets":[{"name":"Featured Collections","blocks":[
{"type":"collection","settings":{"title":"Night Routine"}},
{"type":"collection","settings":{"title":"Travel Essentials"}},
{"type":"collection","settings":{"title":"Vanity Favorites"}},
{"type":"collection","settings":{"title":"Gift Ideas"}}
]}]}{% endschema %}