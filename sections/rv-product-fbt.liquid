
<section class="rv-pdp-section">
  <div class="rv-pdp-fbt">
    <p class="rv-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 style="font-family:var(--rv-serif);font-weight:500;font-size:clamp(24px,2.6vw,36px);color:var(--rv-char);margin:0 0 28px;">{{ section.settings.heading }}</h2>
    <div class="rv-pdp-fbt__items">
      <!-- Current product -->
      <div class="rv-pdp-fbt__item">
        {{ product.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', class: '', alt: product.title }}
        <div class="rv-pdp-fbt__item-name">{{ product.title }}</div>
        <div class="rv-pdp-fbt__item-price">{{ product.price | money }}</div>
      </div>
      {%- for block in section.blocks -%}
        <span class="rv-pdp-fbt__plus">+</span>
        <div class="rv-pdp-fbt__item" {{ block.shopify_attributes }}>
          {%- if block.settings.product != blank -%}
            {%- assign fbt_p = all_products[block.settings.product] -%}
            {%- if fbt_p.featured_image -%}
              {{ fbt_p.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: fbt_p.title }}
            {%- else -%}
              <div class="rv-placeholder-img" style="width:150px;height:150px;">{{ 'product-1' | placeholder_svg_tag }}</div>
            {%- endif -%}
            <div class="rv-pdp-fbt__item-name">{{ fbt_p.title }}</div>
            <div class="rv-pdp-fbt__item-price">{{ fbt_p.price | money }}</div>
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: block.settings.item_name }}
            <div class="rv-pdp-fbt__item-name">{{ block.settings.item_name }}</div>
            <div class="rv-pdp-fbt__item-price">{{ block.settings.item_price }}</div>
          {%- else -%}
            <div class="rv-placeholder-img" style="width:150px;height:150px;">{{ 'product-1' | placeholder_svg_tag }}</div>
            <div class="rv-pdp-fbt__item-name">{{ block.settings.item_name }}</div>
            <div class="rv-pdp-fbt__item-price">{{ block.settings.item_price }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
      <span class="rv-pdp-fbt__plus">=</span>
      <div class="rv-pdp-fbt__total">
        <div class="rv-pdp-fbt__total-label">{{ section.settings.total_label }}</div>
        <div class="rv-pdp-fbt__total-price">
          {{ section.settings.total_price }}
          {%- if section.settings.was_price != blank -%}
            <span class="rv-pdp-fbt__was">{{ section.settings.was_price }}</span>
          {%- endif -%}
        </div>
        <button class="rv-btn rv-btn--primary" style="padding:15px 26px;">Add all to bag</button>
      </div>
    </div>
  </div>
</section>
{% schema %}{"name":"Frequently Bought","tag":"section","max_blocks":2,"settings":[
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Frequently bought together"},
{"type":"text","id":"heading","label":"Heading","default":"Complete the routine"},
{"type":"text","id":"total_label","label":"Total label","default":"Total for all three"},
{"type":"text","id":"total_price","label":"Bundle price (e.g. $84)"},
{"type":"text","id":"was_price","label":"Was price (e.g. $94, shows struck through)"}
],"blocks":[{"type":"fbt_product","name":"Add-on product","settings":[
{"type":"product","id":"product","label":"Shopify product (auto-pulls image)"},
{"type":"image_picker","id":"image","label":"Custom image (if no product above)"},
{"type":"text","id":"item_name","label":"Product name (if no product above)","default":"Add-on"},
{"type":"text","id":"item_price","label":"Price (if no product above)","default":"$28"}
]}],"presets":[{"name":"Frequently Bought Together","blocks":[{"type":"fbt_product"},{"type":"fbt_product"}]}]}{% endschema %}