{%- comment -%} RV-TYPE-GUARD: renders only for matching product types {%- endcomment -%}
{%- assign rvt = product.type | downcase -%}
{%- assign rv_render = false -%}
{%- if rvt contains 'device' or rvt contains 'tool' -%}{%- assign rv_render = true -%}{%- endif -%}
{%- if rv_render -%}

{%- comment -%} Demo video + dermatologist credibility {%- endcomment -%}
<section class="rv-container" style="padding:88px 32px 8px;display:grid;grid-template-columns:1.1fr 1fr;gap:56px;align-items:center;">
  <div style="position:relative;border-radius:4px;overflow:hidden;aspect-ratio:16/10;background:var(--rv-bone-2);">
    {%- if section.settings.video_image != blank -%}
      {{ section.settings.video_image | image_url: width: 1000 | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;', alt: '' }}
    {%- else -%}<div class="rv-placeholder-img" style="width:100%;height:100%;">{{ 'image' | placeholder_svg_tag }}</div>{%- endif -%}
    {%- if section.settings.video_url != blank -%}<a href="{{ section.settings.video_url }}" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(43,42,39,.18);"><span style="width:62px;height:62px;border-radius:999px;background:rgba(251,249,244,.94);display:flex;align-items:center;justify-content:center;color:var(--rv-char);font-size:18px;padding-left:5px;">▶</span></a>{%- endif -%}
    {%- if section.settings.video_label != blank -%}<span style="position:absolute;bottom:14px;left:14px;background:rgba(43,42,39,.8);color:var(--rv-bone);font:600 10px/1 var(--rv-sans);letter-spacing:.1em;text-transform:uppercase;padding:6px 10px;border-radius:999px;">{{ section.settings.video_label }}</span>{%- endif -%}
  </div>
  <div>
    <div style="font:600 12px/1 var(--rv-sans);letter-spacing:.26em;text-transform:uppercase;color:var(--rv-clay);margin-bottom:18px;">{{ section.settings.eyebrow }}</div>
    <p style="font-family:var(--rv-serif);font-style:italic;font-weight:500;font-size:clamp(22px,2.6vw,32px);line-height:1.32;color:var(--rv-char);margin:0 0 24px;">{{ section.settings.quote }}</p>
    <div style="display:flex;align-items:center;gap:14px;">
      {%- if section.settings.author_image != blank -%}{{ section.settings.author_image | image_url: width: 120 | image_tag: loading: 'lazy', style: 'width:54px;height:54px;border-radius:999px;object-fit:cover;flex:none;', alt: '' }}{%- else -%}<div class="rv-placeholder-img" style="width:54px;height:54px;border-radius:999px;flex:none;"></div>{%- endif -%}
      <div>
        <div style="font:600 14px/1.2 var(--rv-sans);color:var(--rv-char);">{{ section.settings.author }}</div>
        <div style="font:400 13px/1.3 var(--rv-sans);color:var(--rv-soft);">{{ section.settings.author_title }}</div>
      </div>
    </div>
  </div>
</section>
<style>@media(max-width:768px){section[style*="1.1fr 1fr"]{grid-template-columns:1fr!important;gap:28px!important;}}</style>

{%- endif -%}
{% schema %}{"name":"Device Demo + Derm","tag":"section","settings":[
{"type":"image_picker","id":"video_image","label":"Video thumbnail"},
{"type":"url","id":"video_url","label":"Video link"},
{"type":"text","id":"video_label","label":"Video label","default":"Watch · 0:60"},
{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Dermatologist approved"},
{"type":"textarea","id":"quote","label":"Quote","default":"Consistent red-light and microcurrent use is one of the most effective at-home ways to support collagen and tone. The Velvet Glow Pro makes the routine genuinely easy to keep."},
{"type":"image_picker","id":"author_image","label":"Author photo"},
{"type":"text","id":"author","label":"Author","default":"Dr. Amara Okafor, MD"},
{"type":"text","id":"author_title","label":"Author title","default":"Board-Certified Dermatologist · Advisor"}
],"presets":[{"name":"Device Demo + Derm"}]}{% endschema %}
